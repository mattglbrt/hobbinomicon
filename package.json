{
  "name": "magenta-meridian",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "sync-vlogs": "node scripts/sync-vlogs.js",
    "backfill-transcripts": "node scripts/backfill-transcripts.js",
    "normalize-transcripts": "node scripts/normalize-transcripts.js",
    "refresh-vlogs": "node scripts/sync-vlogs.js && node scripts/backfill-transcripts.js && node scripts/normalize-transcripts.js && node scripts/download-hero-images.js && git status --short src/content/blog/vlogs",
    "prebuild": "node scripts/sync-vlogs.js && node scripts/backfill-transcripts.js && node scripts/update-youtube-stats.js && node scripts/download-hero-images.js",
    "build": "astro build",
    "postbuild": "pagefind --site dist",
    "preview": "astro preview",
    "astro": "astro",
    "download-heroes": "node scripts/download-hero-images.js",
    "fetch-comments": "node scripts/fetch-youtube-comments.js",
    "fetch-playlist": "node scripts/fetch-playlist-transcripts.js",
    "tag-audit": "node scripts/tag-audit.js",
    "tag-rename": "node scripts/tag-rename.js",
    "validate-schema": "node scripts/validate-schema.js",
    "update-youtube-stats": "node scripts/update-youtube-stats.js",
    "update-descriptions": "node scripts/update-descriptions.cjs",
    "backup-descriptions": "node scripts/backup-descriptions.cjs",
    "youtube-auth": "node scripts/youtube-auth.cjs"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.2",
    "@astrojs/netlify": "^7.0.4",
    "@astrojs/rss": "^4.0.17",
    "@astrojs/sitemap": "^3.7.1",
    "@fontsource-variable/eb-garamond": "^5.2.7",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/sorts-mill-goudy": "^5.2.8",
    "@netlify/blobs": "^10.7.9",
    "@swup/head-plugin": "^2.3.1",
    "@swup/preload-plugin": "^3.2.11",
    "astro": "^6.0.8",
    "googleapis": "^171.4.0",
    "mdast-util-to-string": "^4.0.0",
    "swup": "^4.9.2"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "autoprefixer": "^10.4.27",
    "dotenv": "^17.2.3",
    "netlify-plugin-cache": "^1.0.3",
    "pagefind": "^1.5.2",
    "tailwindcss": "^3.4.18",
    "youtube-transcript-plus": "^1.2.0"
  }
}
