---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PageHeader from '../../components/PageHeader.astro';
import ContentContainer from '../../components/ContentContainer.astro';
import ImageCard from '../../components/ImageCard.astro';
import StructuredData from '../../components/StructuredData.astro';
import { sortByDate } from '../../utils/collections';
import { getHeroImage } from '../../utils/getHeroImage';

const news = sortByDate(await getCollection('news', ({ data }) => !data.draft));

const kindLabels: Record<string, string> = {
  kickstarter: 'Kickstarter',
  release: 'Release',
  errata: 'Errata',
  announcement: 'Announcement',
  interview: 'Interview',
  community: 'Community',
  other: 'News',
};

// Resolve relatedGame for each news item so cards can fall back to the game's
// hero image and pick up its logo for the overlay.
const newsCards = await Promise.all(
  news.map(async (item) => {
    const game = item.data.relatedGame ? await getEntry(item.data.relatedGame) : null;
    const cardImageString = item.data.heroImage || game?.data.heroImage;
    const cardImage = cardImageString ? getHeroImage(cardImageString) : null;
    const logo = game?.data.logo ? getHeroImage(game.data.logo) : null;
    return { item, cardImage, logo };
  })
);
---

<BaseLayout
  title="News | The Hobbinomicon"
  description="Indie wargames news. Kickstarter launches, releases, errata, interviews, and community happenings."
>
  <StructuredData
    type="breadcrumb"
    data={{
      breadcrumbs: [
        { name: 'Home', url: 'https://hobbinomicon.com/' },
        { name: 'News', url: 'https://hobbinomicon.com/news/' },
      ],
    }}
  />
  <Header theme="light" />

  <main id="main-content" class="min-h-screen bg-parchment dark:bg-parchment-dark">
    <PageHeader
      title="News"
      description="What's launching, releasing, and worth knowing in the indie wargame world."
      breadcrumbs={[{ label: 'News', href: '/news' }]}
    />

    <ContentContainer class="py-16">
      {news.length === 0 ? (
        <div class="max-w-2xl mx-auto text-center py-16">
          <h2 class="text-2xl md:text-3xl font-heading font-bold text-ink dark:text-ink-dark mb-4">
            The wire is quiet
          </h2>
          <p class="text-ink/70 dark:text-ink-dark/70 text-lg">
            Indie wargame news, written and curated, kicks off soon. Drop your email below if you want it in your inbox.
          </p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {newsCards.map(({ item, cardImage }) => (
            <ImageCard
              href={`/news/${item.id}/`}
              image={cardImage}
              imageAlt={item.data.heroImageAlt || item.data.title}
              title={item.data.title}
              subtitle={item.data.description}
              fallbackLetter={item.data.title.charAt(0)}
              aspectRatio="16/9"
              variant="stacked"
            />
          ))}
        </div>
      )}
    </ContentContainer>

    <Footer />
  </main>
</BaseLayout>
