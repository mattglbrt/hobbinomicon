---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import DirectoryHero from '../components/DirectoryHero.astro';
import PostGridSection from '../components/PostGridSection.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import Footer from '../components/Footer.astro';
import ContentContainer from '../components/ContentContainer.astro';
import ImageCard from '../components/ImageCard.astro';
import ViewAllLink from '../components/ViewAllLink.astro';
import { getHeroImage } from '../utils/getHeroImage';
import { sortByDate } from '../utils/collections';
import { getVideoCollections } from '../utils/videoCollections';

// ─── Directory: featured / recently added games ─────────────────────
const allGames = await getCollection('games', ({ data }) => !data.draft);
const featuredGames = [...allGames]
  .sort((a, b) => {
    // Indie tier first, then by most recently updated/published
    if (a.data.tier !== b.data.tier) return a.data.tier === 'indie' ? -1 : 1;
    const aDate = (a.data.updatedDate || a.data.pubDate).valueOf();
    const bDate = (b.data.updatedDate || b.data.pubDate).valueOf();
    return bDate - aDate;
  })
  .slice(0, 6);

// ─── Latest indie news ──────────────────────────────────────────────
const allNews = await getCollection('news', ({ data }) => !data.draft);
const recentNews = sortByDate(allNews).slice(0, 6);

// Resolve the related-game (if any) for each news item so news cards can fall
// back to the game's hero image.
const recentNewsCards = await Promise.all(
  recentNews.map(async (item) => {
    const game = item.data.relatedGame ? await getEntry(item.data.relatedGame) : null;
    const cardImageString = item.data.heroImage || game?.data.heroImage;
    const cardImage = cardImageString ? getHeroImage(cardImageString) : null;
    return { item, cardImage };
  })
);

// ─── Latest videos: newest posts from the topic collections only ────
// (never the daily archive — collection membership is the quality filter).
const collections = await getVideoCollections();
const seen = new Set<string>();
const collectionPosts = [];
for (const c of collections) {
  for (const p of c.posts) {
    if (!seen.has(p.id)) { seen.add(p.id); collectionPosts.push(p); }
  }
}
const latestVideos = sortByDate(collectionPosts).slice(0, 3);
---

<BaseLayout
  title="The Hobbinomicon — the indie wargames directory"
  description="A directory and news desk for indie wargames — skirmish, mass battle, TTRPG, and the weird stuff in between. Browse by format, follow the news, and go deeper than the main lines."
>
  <Header theme="dark" />

  <main id="main-content" class="min-h-screen">
    <!-- 1. Hero — directory value proposition + search -->
    <DirectoryHero />

    <!-- 2. Featured / recently added games -->
    {featuredGames.length > 0 && (
      <section class="bg-parchment dark:bg-parchment-dark py-16 md:py-24" data-scroll-reveal>
        <ContentContainer>
          <div class="flex items-center justify-between mb-12">
            <div>
              <span class="block text-sm font-heading uppercase tracking-[0.3em] text-ink/40 dark:text-ink-dark/40 mb-2">Worth a closer look</span>
              <h2 class="text-5xl md:text-7xl font-display font-bold text-ink dark:text-ink-dark">Games worth knowing about</h2>
            </div>
            <ViewAllLink href="/games/">All Games →</ViewAllLink>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {featuredGames.map((game) => {
              const cardImage = game.data.thumbnailImage || game.data.heroImage;
              const resolvedImage = cardImage ? getHeroImage(cardImage) : null;
              const resolvedLogo = game.data.logo ? getHeroImage(game.data.logo) : null;
              const cardAlt = game.data.thumbnailImageAlt || game.data.heroImageAlt || game.data.title;
              return (
                <ImageCard
                  href={`/games/${game.id}/`}
                  image={resolvedImage}
                  imageAlt={cardAlt}
                  title={game.data.title}
                  subtitle={game.data.description}
                  logoOverlay={resolvedLogo}
                  fallbackLetter={game.data.title.charAt(0)}
                  aspectRatio="16/9"
                  variant="overlay"
                  subtitleOnHover
                  titleBelow
                />
              );
            })}
          </div>
        </ContentContainer>
      </section>
    )}

    <!-- 3. Latest indie news -->
    {recentNews.length > 0 && (
      <section class="bg-ink/[0.03] dark:bg-ink-dark/[0.03] py-16 md:py-24" data-scroll-reveal>
        <ContentContainer>
          <div class="flex items-center justify-between mb-12">
            <div>
              <span class="block text-sm font-heading uppercase tracking-[0.3em] text-ink/40 dark:text-ink-dark/40 mb-2">What's new</span>
              <h2 class="text-5xl md:text-7xl font-display font-bold text-ink dark:text-ink-dark">News from the indie wargame world</h2>
            </div>
            <ViewAllLink href="/news/">All News →</ViewAllLink>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {recentNewsCards.map(({ item, cardImage }) => (
              <ImageCard
                href={`/news/${item.id}/`}
                image={cardImage}
                imageAlt={item.data.heroImageAlt || item.data.title}
                title={item.data.title}
                subtitle={item.data.description}
                fallbackLetter={item.data.title.charAt(0)}
                aspectRatio="16/9"
                variant="stacked"
              />
            ))}
          </div>
        </ContentContainer>
      </section>
    )}

    <!-- 4. Latest videos — deep dives & tutorials, capped at 3 -->
    {latestVideos.length > 0 && (
      <PostGridSection
        title="Latest Videos"
        eyebrow="Watch"
        viewAllLink="/videos/"
        posts={latestVideos}
        layout="masonry"
      />
    )}

    <!-- 5. Newsletter — From the Workbench -->
    <div id="newsletter" class="scroll-mt-24">
      <NewsletterSignup variant="section" />
    </div>

    <Footer />
  </main>
</BaseLayout>
