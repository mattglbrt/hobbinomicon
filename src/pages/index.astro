---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import HeroSection from '../components/HeroSection.astro';
import PostGridSection from '../components/PostGridSection.astro';
import FeaturedProjectSection from '../components/FeaturedProjectSection.astro';
import YouTubeCTA from '../components/YouTubeCTA.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import Footer from '../components/Footer.astro';
import ContentContainer from '../components/ContentContainer.astro';
import ImageCard from '../components/ImageCard.astro';
import ViewAllLink from '../components/ViewAllLink.astro';
import { getHeroImage, isImageMetadata } from '../utils/getHeroImage';
import { getPublishedPosts, sortByDate } from '../utils/collections';
import { formatDateLong } from '../utils/formatDate';

// ─── Hero + Latest Vlogs ────────────────────────────────────────────
const allPosts = await getCollection('blog');
const publishedPosts = getPublishedPosts(allPosts);

const featuredPosts = publishedPosts.filter((p) => p.data.featured);
const latestPost = featuredPosts[0] || publishedPosts[0];

const recentVlogs = publishedPosts
  .filter((p) => p.id !== latestPost?.id && p.data.youtubeId)
  .slice(0, 6);

// ─── News ───────────────────────────────────────────────────────────
const allNews = await getCollection('news', ({ data }) => !data.draft);
const recentNews = sortByDate(allNews).slice(0, 5);
const newsKindLabels: Record<string, string> = {
  kickstarter: 'Kickstarter',
  release: 'Release',
  errata: 'Errata',
  announcement: 'Announcement',
  interview: 'Interview',
  community: 'Community',
  other: 'News',
};

// ─── Directory ──────────────────────────────────────────────────────
const allGames = await getCollection('games', ({ data }) => !data.draft);
const featuredGames = [...allGames]
  .sort((a, b) => {
    // Indie tier first, then by most recently updated/published
    if (a.data.tier !== b.data.tier) return a.data.tier === 'indie' ? -1 : 1;
    const aDate = (a.data.updatedDate || a.data.pubDate).valueOf();
    const bDate = (b.data.updatedDate || b.data.pubDate).valueOf();
    return bDate - aDate;
  })
  .slice(0, 6);

// ─── From the Dungeon (Featured Project) ───────────────────────────
const allProjects = await getCollection('projects');
const publishedProjects = allProjects.filter((p) => !p.data.draft);
const projectsWithLatestPost = publishedProjects
  .map((project) => {
    const projectPosts = sortByDate(publishedPosts.filter((post) => post.data.project === project.id));
    return { project, projectSlug: project.id, latestPost: projectPosts[0] };
  })
  .filter((p) => p.latestPost)
  .sort((a, b) => (b.latestPost?.data.pubDate.valueOf() || 0) - (a.latestPost?.data.pubDate.valueOf() || 0));

const featuredProject = projectsWithLatestPost[0];
const featuredProjectPosts = featuredProject
  ? sortByDate(publishedPosts.filter((post) => post.data.project === featuredProject.projectSlug)).slice(0, 4)
  : [];

// ─── Hero LCP preload ───────────────────────────────────────────────
const heroImage = getHeroImage(latestPost?.data.heroImage, latestPost?.data.youtubeId);

import { getImage } from 'astro:assets';
let heroPreloadSrcset = '';
if (heroImage && isImageMetadata(heroImage)) {
  const sizes = [640, 1024, 1280];
  const srcsetParts = await Promise.all(sizes.map(async (w) => {
    const img = await getImage({ src: heroImage, width: w, height: Math.round(w * 9 / 16), format: 'webp', quality: 35 });
    return `${img.src} ${w}w`;
  }));
  heroPreloadSrcset = srcsetParts.join(', ');
}
---

<BaseLayout
  title="The Hobbinomicon"
  description="A directory of indie wargames, daily vlogs from the painting desk, and field notes on the hobby — for players who want to go deeper than the main lines."
>
  {heroPreloadSrcset && (
    <link slot="head" rel="preload" as="image" imagesrcset={heroPreloadSrcset} imagesizes="100vw" fetchpriority="high" />
  )}
  <Header theme="dark" />

  <main id="main-content" class="min-h-screen">
    <!-- 1. Hero — featured / latest big thing -->
    {latestPost && (
      <HeroSection
        slug={latestPost.id}
        title={latestPost.data.title}
        description={latestPost.data.description}
        heroImage={heroImage}
        heroImageAlt={latestPost.data.heroImageAlt}
        category={latestPost.data.category}
        pubDate={latestPost.data.pubDate}
        tags={latestPost.data.tags}
        badge="Featured Post"
        size="large"
      />
    )}

    <!-- 2. Latest Vlogs -->
    <PostGridSection
      title="Latest Vlogs"
      eyebrow="Watch"
      viewAllLink="/vlogs/"
      posts={recentVlogs}
      layout="masonry"
      mobileLimit={3}
    />

    <!-- 3. What's New in Indie Wargaming -->
    {recentNews.length > 0 && (
      <section class="bg-ink/[0.03] dark:bg-ink-dark/[0.03] py-16 md:py-24" data-scroll-reveal>
        <ContentContainer>
          <div class="flex items-center justify-between mb-12">
            <div>
              <span class="block text-sm font-heading uppercase tracking-[0.3em] text-ink/40 dark:text-ink-dark/40 mb-2">From the Underground</span>
              <h2 class="text-5xl md:text-7xl font-display font-bold text-ink dark:text-ink-dark">What's Banging in Indie Wargaming</h2>
            </div>
            <ViewAllLink href="/news/">All News →</ViewAllLink>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 max-w-5xl">
            {recentNews.map((item) => (
              <a href={`/news/${item.id}/`} class="group block p-6 bg-parchment dark:bg-parchment-dark hover:bg-ink/5 dark:hover:bg-ink-dark/10 rounded-lg shadow-sm transition-colors">
                <div class="flex items-center gap-3 mb-2">
                  <span class="text-xs font-heading uppercase tracking-[0.2em] px-2 py-1 bg-ink/10 dark:bg-ink-dark/10 text-ink dark:text-ink-dark rounded">
                    {newsKindLabels[item.data.kind]}
                  </span>
                  <time datetime={item.data.pubDate.toISOString()} class="text-xs text-ink/60 dark:text-ink-dark/60">
                    {formatDateLong(item.data.pubDate)}
                  </time>
                </div>
                <h3 class="text-lg md:text-xl font-heading font-bold text-ink dark:text-ink-dark group-hover:underline mb-2">
                  {item.data.title}
                </h3>
                <p class="text-sm text-ink/70 dark:text-ink-dark/70 line-clamp-2">{item.data.description}</p>
              </a>
            ))}
          </div>
        </ContentContainer>
      </section>
    )}

    <!-- 4. Newsletter CTA -->
    <NewsletterSignup variant="section" />

    <!-- 5. Browse the Directory -->
    {featuredGames.length > 0 && (
      <section class="bg-parchment dark:bg-parchment-dark py-16 md:py-24" data-scroll-reveal>
        <ContentContainer>
          <div class="flex items-center justify-between mb-12">
            <div>
              <span class="block text-sm font-heading uppercase tracking-[0.3em] text-ink/40 dark:text-ink-dark/40 mb-2">Worth a closer look</span>
              <h2 class="text-5xl md:text-7xl font-display font-bold text-ink dark:text-ink-dark">Games worth knowing about</h2>
            </div>
            <ViewAllLink href="/games/">All Games →</ViewAllLink>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {featuredGames.map((game) => {
              const cardImage = game.data.thumbnailImage || game.data.heroImage;
              const resolvedImage = cardImage ? getHeroImage(cardImage) : null;
              const resolvedLogo = game.data.logo ? getHeroImage(game.data.logo) : null;
              const cardAlt = game.data.thumbnailImageAlt || game.data.heroImageAlt || game.data.title;
              return (
                <ImageCard
                  href={`/games/${game.id}/`}
                  image={resolvedImage}
                  imageAlt={cardAlt}
                  title={game.data.title}
                  subtitle={game.data.description}
                  logoOverlay={resolvedLogo}
                  fallbackLetter={game.data.title.charAt(0)}
                  aspectRatio="16/9"
                  variant="overlay"
                  subtitleOnHover
                />
              );
            })}
          </div>
        </ContentContainer>
      </section>
    )}

    <!-- 6. From the Dungeon (Featured Project) -->
    {featuredProject && featuredProjectPosts.length > 0 && (
      <FeaturedProjectSection
        projectSlug={featuredProject.projectSlug}
        project={featuredProject.project}
        posts={featuredProjectPosts}
      />
    )}

    <!-- 7. YouTube CTA -->
    <YouTubeCTA />

    <Footer />
  </main>
</BaseLayout>
