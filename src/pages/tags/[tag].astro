---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import PostCard from '../../components/PostCard.astro';
import Footer from '../../components/Footer.astro';
import StructuredData from '../../components/StructuredData.astro';
import ContentContainer from '../../components/ContentContainer.astro';
import { getPublishedPosts, groupByTags, sortByDate } from '../../utils/collections';
import { getHeroImageUrl } from '../../utils/getHeroImage';
import { getTagDisplay, getTagDescription } from '../../utils/tags';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  const publishedPosts = getPublishedPosts(allPosts);
  const tagsMap = groupByTags(publishedPosts);

  return Array.from(tagsMap.entries()).map(([tag, posts]) => ({
    params: { tag },
    props: { tag, posts: sortByDate(posts) },
  }));
}

const { tag, posts } = Astro.props;

// Get tag display name and description
const tagDisplay = getTagDisplay(tag);
const tagDescription = getTagDescription(tag);

// Social image from the first post
const socialImage = posts[0] ? getHeroImageUrl(posts[0].data.heroImage, posts[0].data.youtubeId) : undefined;
---

<BaseLayout title={`${tagDisplay} - The Hobbinomicon`} description={tagDescription} image={socialImage}>
  <StructuredData
    type="breadcrumb"
    data={{
      breadcrumbs: [
        { name: 'Home', url: 'https://hobbinomicon.com/' },
        { name: 'Blog', url: 'https://hobbinomicon.com/blog' },
        { name: 'Tags', url: 'https://hobbinomicon.com/tags' },
        { name: tagDisplay, url: `https://hobbinomicon.com/tags/${tag}` },
      ],
    }}
  />
  <Header theme="light" />

  <main id="main-content" class="min-h-screen bg-parchment dark:bg-parchment-dark">
    <header class="bg-ink dark:bg-ink-dark text-white pt-36 md:pt-40 pb-16">
      <ContentContainer>
        <a href="/tags" class="inline-block text-white/80 hover:text-white mb-4 transition-colors">
          ← All Tags
        </a>
        <h1 class="text-5xl md:text-6xl font-heading font-bold">#{tagDisplay}</h1>
        {tagDescription && (
          <p class="text-xl text-white/90 mt-4 max-w-2xl">{tagDescription}</p>
        )}
        <p class="text-lg text-white/60 mt-2">{posts.length} {posts.length === 1 ? 'post' : 'posts'}</p>
      </ContentContainer>
    </header>

    <ContentContainer class="py-16">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map((post) => (
          <PostCard post={post} />
        ))}
      </div>
    </ContentContainer>

    <Footer />
  </main>
</BaseLayout>
