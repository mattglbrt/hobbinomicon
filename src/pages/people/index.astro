---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PageHeader from '../../components/PageHeader.astro';
import ContentContainer from '../../components/ContentContainer.astro';
import ImageCard from '../../components/ImageCard.astro';
import StructuredData from '../../components/StructuredData.astro';

const people = (await getCollection('people', ({ data }) => !data.draft))
  .sort((a, b) => a.data.name.localeCompare(b.data.name));
---

<BaseLayout
  title="People — The Hobbinomicon"
  description="Designers, sculptors, painters, podcasters, and content creators in the indie wargame scene."
>
  <StructuredData
    type="breadcrumb"
    data={{
      breadcrumbs: [
        { name: 'Home', url: 'https://hobbinomicon.com/' },
        { name: 'People', url: 'https://hobbinomicon.com/people' },
      ],
    }}
  />
  <Header theme="light" />

  <main id="main-content" class="min-h-screen bg-parchment dark:bg-parchment-dark">
    <PageHeader
      title="People"
      description="Designers, sculptors, painters, podcasters, and content creators worth knowing in the indie scene."
      breadcrumbs={[{ label: 'People', href: '/people' }]}
    />

    <ContentContainer class="py-16">
      {people.length === 0 ? (
        <div class="max-w-2xl mx-auto text-center py-16">
          <h2 class="text-2xl md:text-3xl font-heading font-bold text-ink dark:text-ink-dark mb-4">
            No profiles yet
          </h2>
          <p class="text-ink/70 dark:text-ink-dark/70 text-lg">
            Designers, sculptors, painters, podcasters, and creators — all in the queue. Patience, friend.
          </p>
        </div>
      ) : (
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-6">
          {people.map((person) => (
            <ImageCard
              href={`/people/${person.id}/`}
              image={person.data.heroImage}
              imageAlt={person.data.heroImageAlt || person.data.name}
              title={person.data.name}
              subtitle={person.data.roles.length > 0 ? person.data.roles[0] : undefined}
              fallbackLetter={person.data.name.charAt(0)}
              aspectRatio="2/3"
              variant="overlay"
            />
          ))}
        </div>
      )}
    </ContentContainer>

    <Footer />
  </main>
</BaseLayout>
