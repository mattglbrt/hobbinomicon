---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PageHeader from '../../components/PageHeader.astro';
import ContentContainer from '../../components/ContentContainer.astro';
import GameGrid from '../../components/GameGrid.astro';
import StructuredData from '../../components/StructuredData.astro';
import { sortGamesPinnedThenTitle } from '../../utils/collections';

const allGames = await getCollection('games', ({ data }) => !data.draft);
const games = sortGamesPinnedThenTitle(
  allGames.filter((g) => g.data.format === 'narrative')
);
---

<BaseLayout
  title="Narrative Games | The Hobbinomicon"
  description="Story and scenario-driven miniature games. Often solo or co-op, often niche, often the most interesting corner of the hobby."
>
  <StructuredData
    type="breadcrumb"
    data={{
      breadcrumbs: [
        { name: 'Home', url: 'https://hobbinomicon.com/' },
        { name: 'Games', url: 'https://hobbinomicon.com/games/' },
        { name: 'Narrative', url: 'https://hobbinomicon.com/games/narrative/' },
      ],
    }}
  />
  <Header theme="light" />

  <main id="main-content" class="min-h-screen bg-parchment dark:bg-parchment-dark">
    <PageHeader
      title="Narrative Games"
      description="Story and scenario-driven miniature games. Often solo or co-op, often niche, often the most interesting corner of the hobby."
      breadcrumbs={[
        { label: 'Games', href: '/games' },
        { label: 'Narrative', href: '/games/narrative' },
      ]}
    />

    <ContentContainer class="py-16">
      <GameGrid
        games={games}
        emptyTitle="No narrative games yet"
        emptyMessage="Working on it. The first batch will land soon."
      />
    </ContentContainer>

    <Footer />
  </main>
</BaseLayout>
