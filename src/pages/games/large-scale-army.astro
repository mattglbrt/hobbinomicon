---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PageHeader from '../../components/PageHeader.astro';
import ContentContainer from '../../components/ContentContainer.astro';
import GameGrid from '../../components/GameGrid.astro';
import StructuredData from '../../components/StructuredData.astro';
import { sortGamesPinnedThenTitle } from '../../utils/collections';

const allGames = await getCollection('games', ({ data }) => !data.draft);
const games = sortGamesPinnedThenTitle(
  allGames.filter((g) => g.data.format === 'large-scale-army')
);
---

<BaseLayout
  title="Large Scale Army Games | The Hobbinomicon"
  description="Command-led miniature wargames bigger than skirmish but tighter than rank-and-flank. 15 to 30 models, a single commander, every activation matters."
>
  <StructuredData
    type="breadcrumb"
    data={{
      breadcrumbs: [
        { name: 'Home', url: 'https://hobbinomicon.com/' },
        { name: 'Games', url: 'https://hobbinomicon.com/games/' },
        { name: 'Large Scale Army', url: 'https://hobbinomicon.com/games/large-scale-army/' },
      ],
    }}
  />
  <Header theme="light" />

  <main id="main-content" class="min-h-screen bg-parchment dark:bg-parchment-dark">
    <PageHeader
      title="Large Scale Army Games"
      description="Command-led miniature wargames bigger than skirmish but tighter than rank-and-flank. 15 to 30 models, a single commander, every activation matters."
      breadcrumbs={[
        { label: 'Games', href: '/games' },
        { label: 'Large Scale Army', href: '/games/large-scale-army' },
      ]}
    />

    <ContentContainer class="py-16">
      <GameGrid
        games={games}
        emptyTitle="No large scale army games yet"
        emptyMessage="Working on it. The first batch will land soon."
      />
    </ContentContainer>

    <Footer />
  </main>
</BaseLayout>
