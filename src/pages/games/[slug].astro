---
import { Image } from 'astro:assets';
import { getCollection, getEntry, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ContentContainer from '../../components/ContentContainer.astro';
import ProseContent from '../../components/ProseContent.astro';
import PostCard from '../../components/PostCard.astro';
import StructuredData from '../../components/StructuredData.astro';
import { formatDateLong } from '../../utils/formatDate';
import { getPublishedPosts, sortByDate } from '../../utils/collections';
import { getHeroImage, isImageMetadata } from '../../utils/getHeroImage';
import GameSpecs from '../../components/GameSpecs.astro';
import ImageCard from '../../components/ImageCard.astro';

const newsKindLabels: Record<string, string> = {
  kickstarter: 'Kickstarter',
  release: 'Release',
  errata: 'Errata',
  announcement: 'Announcement',
  interview: 'Interview',
  community: 'Community',
  other: 'News',
};

export async function getStaticPaths() {
  const games = await getCollection('games', ({ data }) => !data.draft);
  return games.map((game) => ({
    params: { slug: game.id },
    props: { game },
  }));
}

const { game } = Astro.props;
const { Content } = await render(game);

// Resolve studio + designers
const studio = game.data.studio ? await getEntry(game.data.studio) : null;
const designers = await Promise.all(
  game.data.designers.map((ref) => getEntry(ref))
);

// Resolve related games
const relatedGames = await Promise.all(
  game.data.relatedGames.map((ref) => getEntry(ref))
);

// Living feed: only blog posts tagged with this game's slug.
// Generic tags like 'narrative' or 'fantasy' on the game itself drive the
// funnel/discovery elsewhere; here we want strictly first-party content
// about this specific game.
const allBlog = await getCollection('blog');
const publishedBlog = getPublishedPosts(allBlog);
const matchingPosts = publishedBlog
  .filter((post) => post.data.tags?.includes(game.id))
  .slice(0, 6);

// News tagged to this game
const allNews = await getCollection('news', ({ data }) => !data.draft);
const gameNews = sortByDate(
  allNews.filter((n) => n.data.relatedGame?.id === game.id)
).slice(0, 6);

// Reference card link list — flatten to array of {label, url}
const referenceLinks = [
  { label: 'Official Site', url: game.data.officialUrl },
  { label: 'Buy', url: game.data.storeUrl },
  { label: 'Rules', url: game.data.rulesUrl },
  { label: 'Official Discord', url: game.data.discordUrl },
  { label: 'Subreddit', url: game.data.subredditUrl },
  { label: 'Kickstarter', url: game.data.kickstarterUrl },
  { label: 'Facebook', url: game.data.facebookUrl },
].filter((l): l is { label: string; url: string } => Boolean(l.url));

const hasReferenceCard = Boolean(studio) || designers.length > 0 || referenceLinks.length > 0;
const hasSidebar =
  hasReferenceCard ||
  game.data.podcasts.length > 0 ||
  game.data.creators.length > 0 ||
  relatedGames.length > 0;

const statusLabel: Record<string, string> = {
  active: 'Active',
  oop: 'Out of Print',
  kickstarter: 'On Kickstarter',
  announced: 'Announced',
};

const resolvedLogo = game.data.logo ? getHeroImage(game.data.logo) : null;
const logoIsOptimized = resolvedLogo && isImageMetadata(resolvedLogo);

const resolvedHero = game.data.heroImage ? getHeroImage(game.data.heroImage) : null;
const heroIsOptimized = resolvedHero && isImageMetadata(resolvedHero);

// Build the spec pill row from schema fields. Only included pills that have a value.
// The Minis pill is always shown — derived from the miniatureAgnostic flag.
const gameSpecs = [
  game.data.playerCount && { label: 'Players', value: game.data.playerCount },
  game.data.modelCount && { label: 'Models', value: game.data.modelCount },
  game.data.boardSize && { label: 'Board', value: game.data.boardSize },
  game.data.pointsScale && { label: 'Points', value: game.data.pointsScale },
  game.data.gameLength && { label: 'Length', value: game.data.gameLength },
  game.data.costToStart && { label: 'Cost', value: game.data.costToStart },
  { label: 'Minis', value: game.data.miniatureAgnostic ? 'Mini-Agnostic' : 'Not Mini-Agnostic' },
].filter((s): s is { label: string; value: string } => Boolean(s));
---

<BaseLayout
  title={`${game.data.title} | The Hobbinomicon`}
  description={game.data.description}
  image={game.data.heroImage}
>
  <StructuredData
    type="breadcrumb"
    data={{
      breadcrumbs: [
        { name: 'Home', url: 'https://hobbinomicon.com/' },
        { name: 'Games', url: 'https://hobbinomicon.com/games/' },
        { name: game.data.title, url: `https://hobbinomicon.com/games/${game.id}/` },
      ],
    }}
  />
  <StructuredData
    type="game"
    data={{
      name: game.data.title,
      description: game.data.description,
      url: `https://hobbinomicon.com/games/${game.id}/`,
      image: game.data.heroImage ? new URL(game.data.heroImage, 'https://hobbinomicon.com').toString() : undefined,
      datePublished: game.data.pubDate,
      dateModified: game.data.updatedDate,
      releaseYear: game.data.releaseYear,
      publisher: studio ? {
        name: studio.data.name,
        url: `https://hobbinomicon.com/studios/${studio.id}/`,
      } : undefined,
      designers: designers.map((d) => ({
        name: d.data.name,
        url: `https://hobbinomicon.com/people/${d.id}/`,
      })),
      genre: game.data.tags,
    }}
  />
  <Header theme={game.data.heroImage ? 'dark' : 'light'} />

  <main id="main-content" class="min-h-screen bg-parchment dark:bg-parchment-dark">
    {resolvedHero ? (
      <div class="relative h-[50vh] md:h-[60vh] overflow-hidden">
        {heroIsOptimized ? (
          <Image
            src={resolvedHero}
            alt={game.data.heroImageAlt || game.data.title}
            class="w-full h-full object-cover object-center"
            loading="eager"
            decoding="sync"
            format="webp"
            quality={50}
            widths={[640, 1024, 1920]}
            sizes="100vw"
            width={1920}
            height={1080}
          />
        ) : (
          <img
            src={resolvedHero}
            alt={game.data.heroImageAlt || game.data.title}
            class="w-full h-full object-cover object-center"
            loading="eager"
          />
        )}
        <div class="absolute inset-0 bg-gradient-to-t from-parchment dark:from-parchment-dark via-ink/40 to-transparent"></div>
      </div>
    ) : (
      <div class="pt-32"></div>
    )}

    <article class={`pb-20 md:pb-24 ${game.data.heroImage ? '-mt-32 relative z-10' : ''}`}>
      <ContentContainer>
        <header class="mb-12">
          <div class="flex flex-wrap justify-center gap-3 mb-6">
            <span class="px-3 py-1 bg-white text-ink text-xs font-heading uppercase tracking-[0.2em] rounded-full shadow-sm">
              {game.data.tier === 'indie' ? 'Indie' : 'Big Game'}
            </span>
            <span class="px-3 py-1 bg-white text-ink text-xs font-heading uppercase tracking-[0.2em] rounded-full shadow-sm">
              {statusLabel[game.data.status]}
            </span>
            {game.data.currentEdition && (
              <span class="px-3 py-1 bg-white text-ink text-xs font-heading uppercase tracking-[0.2em] rounded-full shadow-sm">
                {game.data.currentEdition}
              </span>
            )}
            {game.data.releaseYear && (
              <span class="px-3 py-1 bg-white text-ink text-xs font-heading uppercase tracking-[0.2em] rounded-full shadow-sm">
                {game.data.releaseYear}
              </span>
            )}
          </div>
          <div class="flex flex-col items-center gap-6 mb-6">
            {resolvedLogo && (
              logoIsOptimized ? (
                <Image
                  src={resolvedLogo}
                  alt={game.data.logoAlt || `${game.data.title} logo`}
                  class="h-40 md:h-44 w-auto max-w-full object-contain"
                  loading="eager"
                  format="webp"
                  quality={80}
                />
              ) : (
                <img
                  src={resolvedLogo}
                  alt={game.data.logoAlt || `${game.data.title} logo`}
                  class="h-40 md:h-44 w-auto max-w-full object-contain"
                  loading="eager"
                />
              )
            )}
            <h1 class="text-4xl md:text-6xl font-display font-bold text-ink dark:text-ink-dark leading-tight text-center">
              {game.data.title}
            </h1>
          </div>
          <p class="text-xl md:text-2xl text-ink/80 dark:text-ink-dark/80 font-serif italic max-w-3xl border-l-4 border-ink/30 dark:border-ink-dark/30 pl-6">
            {game.data.description}
          </p>
          <GameSpecs specs={gameSpecs} />
        </header>

        <div class={hasSidebar ? 'grid grid-cols-1 lg:grid-cols-3 gap-12' : 'max-w-3xl'}>
          <div class={hasSidebar ? 'lg:col-span-2' : ''}>
            {game.data.verdict && (
              <blockquote class="not-prose mb-12 p-6 bg-ink/5 dark:bg-ink-dark/5 border-l-4 border-ink dark:border-ink-dark rounded-r-lg">
                <p class="text-lg md:text-xl font-serif italic text-ink dark:text-ink-dark">
                  "{game.data.verdict}"
                </p>
                <footer class="mt-3 text-sm text-ink/60 dark:text-ink-dark/60 font-heading uppercase tracking-wider">
                  The Hobbinomicon Take
                </footer>
              </blockquote>
            )}

            <ProseContent>
              <Content />
            </ProseContent>
          </div>

          {hasSidebar && (
          <aside class="space-y-8">
            {hasReferenceCard && (
            <div class="bg-ink/5 dark:bg-ink-dark/5 p-6 rounded-lg">
              <h2 class="text-sm font-heading uppercase tracking-[0.2em] text-ink/60 dark:text-ink-dark/60 mb-4">
                Reference
              </h2>
              <dl class="space-y-3 text-sm">
                {studio && (
                  <div>
                    <dt class="text-ink/60 dark:text-ink-dark/60">Publisher</dt>
                    <dd class="text-ink dark:text-ink-dark font-medium">
                      <a href={`/studios/${studio.id}/`} class="hover:underline">{studio.data.name}</a>
                    </dd>
                  </div>
                )}
                {designers.length > 0 && (
                  <div>
                    <dt class="text-ink/60 dark:text-ink-dark/60">{designers.length === 1 ? 'Designer' : 'Designers'}</dt>
                    <dd class="text-ink dark:text-ink-dark font-medium">
                      {designers.map((d, i) => (
                        <>
                          <a href={`/people/${d.id}/`} class="hover:underline">{d.data.name}</a>
                          {i < designers.length - 1 && <span>, </span>}
                        </>
                      ))}
                    </dd>
                  </div>
                )}
                {referenceLinks.length > 0 && (
                  <div class="pt-3 border-t border-ink/10 dark:border-ink-dark/10">
                    <dt class="text-ink/60 dark:text-ink-dark/60 mb-2">Links</dt>
                    <dd class="flex flex-col gap-1">
                      {referenceLinks.map((link) => (
                        <a
                          href={link.url}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="text-ink dark:text-ink-dark hover:underline"
                        >
                          {link.label} →
                        </a>
                      ))}
                    </dd>
                  </div>
                )}
              </dl>
            </div>
            )}

            {game.data.podcasts.length > 0 && (
              <div class="bg-ink/5 dark:bg-ink-dark/5 p-6 rounded-lg">
                <h2 class="text-sm font-heading uppercase tracking-[0.2em] text-ink/60 dark:text-ink-dark/60 mb-4">
                  Podcasts
                </h2>
                <ul class="space-y-2 text-sm">
                  {game.data.podcasts.map((p) => (
                    <li>
                      <a href={p.url} target="_blank" rel="noopener noreferrer" class="text-ink dark:text-ink-dark hover:underline">
                        {p.name} →
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            )}

            {game.data.creators.length > 0 && (
              <div class="bg-ink/5 dark:bg-ink-dark/5 p-6 rounded-lg">
                <h2 class="text-sm font-heading uppercase tracking-[0.2em] text-ink/60 dark:text-ink-dark/60 mb-4">
                  Content Creators
                </h2>
                <ul class="space-y-2 text-sm">
                  {game.data.creators.map((c) => (
                    <li>
                      <a href={c.url} target="_blank" rel="noopener noreferrer" class="text-ink dark:text-ink-dark hover:underline">
                        {c.name} →
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            )}

            {relatedGames.length > 0 && (
              <div class="bg-ink/5 dark:bg-ink-dark/5 p-6 rounded-lg">
                <h2 class="text-sm font-heading uppercase tracking-[0.2em] text-ink/60 dark:text-ink-dark/60 mb-4">
                  If you like this, try
                </h2>
                <ul class="space-y-2 text-sm">
                  {relatedGames.map((rg) => (
                    <li>
                      <a href={`/games/${rg.id}/`} class="text-ink dark:text-ink-dark hover:underline font-medium">
                        {rg.data.title} →
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </aside>
          )}
        </div>

        {gameNews.length > 0 && (
          <section class="mt-20 pt-12 border-t border-ink/10 dark:border-ink-dark/10">
            <h2 class="text-3xl md:text-4xl font-heading font-bold text-ink dark:text-ink-dark mb-8">
              News
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              {gameNews.map((n) => {
                const cardImageString = n.data.heroImage || game.data.heroImage;
                const cardImage = cardImageString ? getHeroImage(cardImageString) : null;
                return (
                  <ImageCard
                    href={`/news/${n.id}/`}
                    image={cardImage}
                    imageAlt={n.data.heroImageAlt || n.data.title}
                    title={n.data.title}
                    subtitle={n.data.description}
                    fallbackLetter={n.data.title.charAt(0)}
                    aspectRatio="16/9"
                    variant="stacked"
                  />
                );
              })}
            </div>
          </section>
        )}

        {matchingPosts.length > 0 && (
          <section class="mt-20 pt-12 border-t border-ink/10 dark:border-ink-dark/10">
            <h2 class="text-3xl md:text-4xl font-heading font-bold text-ink dark:text-ink-dark mb-8">
              From the Hobbinomicon
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
              {matchingPosts.map((post) => <PostCard post={post} />)}
            </div>
          </section>
        )}
      </ContentContainer>
    </article>

    <Footer />
  </main>
</BaseLayout>
