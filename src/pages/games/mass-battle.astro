---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PageHeader from '../../components/PageHeader.astro';
import ContentContainer from '../../components/ContentContainer.astro';
import GameGrid from '../../components/GameGrid.astro';
import StructuredData from '../../components/StructuredData.astro';
import { sortGamesPinnedThenTitle } from '../../utils/collections';

const allGames = await getCollection('games', ({ data }) => !data.draft);
const games = sortGamesPinnedThenTitle(
  allGames.filter((g) => g.data.format === 'mass-battle')
);
---

<BaseLayout
  title="Rank and Flank Games | The Hobbinomicon"
  description="Rank-and-file and army-scale wargames. Push around your blocks of dudes."
>
  <StructuredData
    type="breadcrumb"
    data={{
      breadcrumbs: [
        { name: 'Home', url: 'https://hobbinomicon.com/' },
        { name: 'Games', url: 'https://hobbinomicon.com/games/' },
        { name: 'Rank and Flank', url: 'https://hobbinomicon.com/games/mass-battle/' },
      ],
    }}
  />
  <Header theme="light" />

  <main id="main-content" class="min-h-screen bg-parchment dark:bg-parchment-dark">
    <PageHeader
      title="Rank and Flank Games"
      description="Rank-and-file and army-scale wargames. Push around your blocks of dudes."
      breadcrumbs={[
        { label: 'Games', href: '/games' },
        { label: 'Rank and Flank', href: '/games/mass-battle' },
      ]}
    />

    <ContentContainer class="py-16">
      <GameGrid
        games={games}
        emptyTitle="No Rank and Flank games yet"
        emptyMessage="Working on it. The first batch will land soon."
      />
    </ContentContainer>

    <Footer />
  </main>
</BaseLayout>
