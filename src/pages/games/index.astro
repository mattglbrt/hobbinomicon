---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PageHeader from '../../components/PageHeader.astro';
import ContentContainer from '../../components/ContentContainer.astro';
import GameGrid from '../../components/GameGrid.astro';
import StructuredData from '../../components/StructuredData.astro';
import { sortGamesPinnedThenTitle } from '../../utils/collections';

const allGames = await getCollection('games', ({ data }) => !data.draft);

const ttrpgs = sortGamesPinnedThenTitle(
  allGames.filter((g) => g.data.format === 'ttrpg' && g.data.status !== 'oop')
).slice(0, 6);
const skirmish = sortGamesPinnedThenTitle(
  allGames.filter((g) => g.data.format === 'skirmish')
).slice(0, 6);
const largeScaleArmy = sortGamesPinnedThenTitle(
  allGames.filter((g) => g.data.format === 'large-scale-army' && g.data.status !== 'oop')
).slice(0, 6);
const massBattle = sortGamesPinnedThenTitle(
  allGames.filter((g) => g.data.format === 'mass-battle' && g.data.status !== 'oop')
).slice(0, 6);
const graveyard = sortGamesPinnedThenTitle(
  allGames.filter((g) => g.data.status === 'oop')
).slice(0, 6);

const soloCount = allGames.filter((g) => g.data.solo === true && g.data.status !== 'oop').length;
---

<BaseLayout
  title="Games | The Hobbinomicon"
  description="A directory of indie wargames, GW Specialist Games, classic Warhammer editions, and standalone miniature lines. Browse by format."
>
  <StructuredData
    type="breadcrumb"
    data={{
      breadcrumbs: [
        { name: 'Home', url: 'https://hobbinomicon.com/' },
        { name: 'Games', url: 'https://hobbinomicon.com/games/' },
      ],
    }}
  />
  <Header theme="light" />

  <main id="main-content" class="min-h-screen bg-parchment dark:bg-parchment-dark">
    <PageHeader
      title="Games"
      description="A directory of indie wargames, GW Specialist Games, classic editions, and the standalone miniature lines worth knowing about. Browse by format below."
      breadcrumbs={[{ label: 'Games', href: '/games' }]}
    />

    <ContentContainer class="py-16 space-y-20">
      <!-- Skirmish -->
      <section>
        <div class="flex items-baseline justify-between mb-2 gap-4">
          <h2 class="text-3xl md:text-4xl font-heading font-bold text-ink dark:text-ink-dark">
            <a href="/games/skirmish/" class="hover:underline underline-offset-4">Skirmish</a>
          </h2>
          <a href="/games/skirmish/" class="text-ink/70 dark:text-ink-dark/70 hover:text-ink dark:hover:text-ink-dark text-sm font-medium whitespace-nowrap">
            View all →
          </a>
        </div>
        <p class="text-ink/70 dark:text-ink-dark/70 text-lg mb-8">
          Small-warband miniature games. Low buy-in, narrative-friendly, easy to start.
        </p>
        <GameGrid
          games={skirmish}
          emptyTitle="Nothing here yet"
          emptyMessage="Skirmish games are coming. Working through the list."
        />
      </section>

      <!-- Large Scale Army -->
      <section>
        <div class="flex items-baseline justify-between mb-2 gap-4">
          <h2 class="text-3xl md:text-4xl font-heading font-bold text-ink dark:text-ink-dark">
            <a href="/games/large-scale-army/" class="hover:underline underline-offset-4">Large Scale Army</a>
          </h2>
          <a href="/games/large-scale-army/" class="text-ink/70 dark:text-ink-dark/70 hover:text-ink dark:hover:text-ink-dark text-sm font-medium whitespace-nowrap">
            View all →
          </a>
        </div>
        <p class="text-ink/70 dark:text-ink-dark/70 text-lg mb-8">
          Full size army wargames.
        </p>
        <GameGrid
          games={largeScaleArmy}
          emptyTitle="Nothing here yet"
          emptyMessage="Large Scale Army coverage is coming."
        />
      </section>

      <!-- Rank and Flank -->
      <section>
        <div class="flex items-baseline justify-between mb-2 gap-4">
          <h2 class="text-3xl md:text-4xl font-heading font-bold text-ink dark:text-ink-dark">
            <a href="/games/mass-battle/" class="hover:underline underline-offset-4">Rank and Flank</a>
          </h2>
          <a href="/games/mass-battle/" class="text-ink/70 dark:text-ink-dark/70 hover:text-ink dark:hover:text-ink-dark text-sm font-medium whitespace-nowrap">
            View all →
          </a>
        </div>
        <p class="text-ink/70 dark:text-ink-dark/70 text-lg mb-8">
          Rank-and-file and army-scale wargames. Push around your blocks of dudes.
        </p>
        <GameGrid
          games={massBattle}
          emptyTitle="Nothing here yet"
          emptyMessage="Rank and Flank coverage is coming."
        />
      </section>

      <!-- TTRPGs -->
      <section>
        <div class="flex items-baseline justify-between mb-2 gap-4">
          <h2 class="text-3xl md:text-4xl font-heading font-bold text-ink dark:text-ink-dark">
            <a href="/games/ttrpgs/" class="hover:underline underline-offset-4">TTRPGs</a>
          </h2>
          <a href="/games/ttrpgs/" class="text-ink/70 dark:text-ink-dark/70 hover:text-ink dark:hover:text-ink-dark text-sm font-medium whitespace-nowrap">
            View all →
          </a>
        </div>
        <p class="text-ink/70 dark:text-ink-dark/70 text-lg mb-8">
          Tabletop RPGs. Narrative, OSR, and the weirder corners.
        </p>
        <GameGrid
          games={ttrpgs}
          emptyTitle="Nothing here yet"
          emptyMessage="TTRPGs are coming. The first batch is in the roadmap."
        />
      </section>

      <!-- The Graveyard -->
      {graveyard.length > 0 && (
        <section>
          <div class="flex items-baseline justify-between mb-2 gap-4">
            <h2 class="text-3xl md:text-4xl font-heading font-bold text-ink dark:text-ink-dark">
              <a href="/games/graveyard/" class="hover:underline underline-offset-4">The Graveyard</a>
            </h2>
            <a href="/games/graveyard/" class="text-ink/70 dark:text-ink-dark/70 hover:text-ink dark:hover:text-ink-dark text-sm font-medium whitespace-nowrap">
              View all →
            </a>
          </div>
          <p class="text-ink/70 dark:text-ink-dark/70 text-lg mb-8 max-w-3xl">
            Officially out of print. Still on the table somewhere. The community has kept these dead games alive.
          </p>
          <GameGrid games={graveyard} />
        </section>
      )}

      <!-- Solo cross-link -->
      {soloCount > 0 && (
        <section class="border-t border-ink/10 dark:border-ink-dark/10 pt-12">
          <p class="text-ink/70 dark:text-ink-dark/70 text-lg">
            Looking for games that work without an opponent?{' '}
            <a href="/games/solo/" class="text-ink dark:text-ink-dark font-medium underline underline-offset-4 hover:no-underline">
              Browse solo-friendly games →
            </a>
          </p>
        </section>
      )}
    </ContentContainer>

    <Footer />
  </main>
</BaseLayout>
