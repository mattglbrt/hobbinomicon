---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Secret Toad - The Hobbinomicon"
  description="A mysterious toad with a special license for spreading pestilence across the world."
>
  <Header theme="light" />

  <main id="main-content" class="min-h-screen bg-parchment">
    <!-- Hero Section -->
    <section class="relative bg-ink text-white py-16 md:py-24 overflow-hidden">
      <div class="absolute inset-0 opacity-10">
        <div class="absolute inset-0 bg-gradient-to-br from-parchment/20 to-transparent"></div>
      </div>

      <div class="max-w-6xl mx-auto px-6 relative z-10">
        <a href="/" class="inline-block text-white/80 hover:text-white mb-6 transition-colors">
          ← Back to Home
        </a>
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-heading font-bold mb-4">
          The Secret Toad
        </h1>
        <p class="text-2xl md:text-3xl text-white/90 italic font-serif">
          A mission of pestilent proliferation
        </p>
      </div>
    </section>

    <!-- Product Section -->
    <section class="max-w-6xl mx-auto px-6 py-16 md:py-24">
      <div class="grid md:grid-cols-2 gap-12 items-start">
        <!-- Product Image (Sticky) -->
        <div class="md:sticky md:top-24">
          <div class="bg-white p-8 rounded-lg shadow-xl border-2 border-ink/10">
            <img
              src="/images/miscasttoad.jpg"
              alt="The Secret Toad"
              class="w-full h-auto rounded-lg shadow-md"
            />
            <p class="text-center text-sm text-ink/70 mt-4 font-mono">
              * Color selected at random
            </p>
          </div>
        </div>

        <!-- Product Details (Scrollable) -->
        <div>
          <div class="bg-white/50 backdrop-blur-sm p-8 rounded-lg border-2 border-ink/10 mb-8">
            <h2 class="text-3xl font-heading font-bold text-ink mb-6">About This Toad</h2>

            <div class="prose prose-lg max-w-none mb-6">
              <p class="text-ink/80 leading-relaxed mb-4">
                These are hand cast by me and might have minor imperfections or need some hobby love.
              </p>

              <p class="text-ink/80 leading-relaxed mb-4">
                These toads come with a license for recasting that states:
              </p>

              <div class="bg-ink/5 border-l-4 border-ink/40 p-6 my-6 font-mono text-sm">
                <p class="text-ink/90 leading-relaxed mb-4">
                  <em>This toad's mission is to spread copies of its pestilent self all over the world.</em>
                </p>
                <p class="text-ink/90 leading-relaxed mb-4">
                  By owning this toad model you have permission to recast it, modify it and make as many duplicates as you like for personal and commercial use under the following condition:
                </p>
                <p class="text-ink/90 leading-relaxed mb-4">
                  <strong>All recasts of this model and modifications to it must also include a copy of and follow this license.</strong>
                </p>
                <p class="text-ink/90 leading-relaxed">
                  Love from<br/>
                  <strong>Trent Holbrook</strong>
                </p>
              </div>

              <p class="text-ink/80 leading-relaxed">
                <strong>Note:</strong> These Toads come in a variety of colors and will be selected at random.
              </p>
            </div>
          </div>

          <!-- Sold Out Notice -->
          <div class="bg-ink text-white p-8 rounded-lg text-center">
            <h3 class="text-2xl font-heading font-bold mb-4">Currently Sold Out</h3>
            <p class="text-white/80 mb-6">
              The toads are currently sold out. Check back later for more pestilent proliferation.
            </p>
          </div>
        </div>
      </div>
    </section>

    <Footer />
  </main>
</BaseLayout>
