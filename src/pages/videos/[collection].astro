---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PageHeader from '../../components/PageHeader.astro';
import ContentContainer from '../../components/ContentContainer.astro';
import VideoCard from '../../components/VideoCard.astro';
import StructuredData from '../../components/StructuredData.astro';
import { getVideoCollections } from '../../utils/videoCollections';

export const getStaticPaths = (async () => {
  const collections = await getVideoCollections();
  return collections.map((c) => ({ params: { collection: c.slug }, props: { c } }));
}) satisfies GetStaticPaths;

const { c } = Astro.props;
const utm = 'utm_source=hobbinomicon&utm_medium=directory';
---

<BaseLayout
  title={`${c.title} | Videos | The Hobbinomicon`}
  description={c.description}
>
  <StructuredData
    type="breadcrumb"
    data={{
      breadcrumbs: [
        { name: 'Home', url: 'https://hobbinomicon.com/' },
        { name: 'Videos', url: 'https://hobbinomicon.com/videos/' },
        { name: c.title, url: `https://hobbinomicon.com/videos/${c.slug}/` },
      ],
    }}
  />
  <Header theme="light" />

  <main id="main-content" class="min-h-screen bg-parchment dark:bg-parchment-dark">
    <PageHeader
      title={c.title}
      description={c.description}
      breadcrumbs={[{ label: 'Videos', href: '/videos' }, { label: c.title, href: `/videos/${c.slug}` }]}
    />

    <ContentContainer class="py-8">
      {c.playlistUrl && (
        <p class="mb-8">
          <a href={`${c.playlistUrl}?${utm}`} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-ink dark:text-ink-dark font-medium underline underline-offset-4 hover:no-underline">
            Watch this collection as a YouTube playlist →
          </a>
        </p>
      )}
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {c.posts.map((post) => <VideoCard post={post} />)}
      </div>
    </ContentContainer>

    <Footer />
  </main>
</BaseLayout>
