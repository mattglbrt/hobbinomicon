---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PageHeader from '../../components/PageHeader.astro';
import ContentContainer from '../../components/ContentContainer.astro';
import VideoCard from '../../components/VideoCard.astro';
import StructuredData from '../../components/StructuredData.astro';
import { getVideoCollections, getArchivePosts } from '../../utils/videoCollections';

const collections = await getVideoCollections();
const archiveCount = (await getArchivePosts()).length;
const utm = 'utm_source=hobbinomicon&utm_medium=directory';
---

<BaseLayout
  title="Videos | The Hobbinomicon"
  description="Deep dives, painting and terrain tutorials, and indie game coverage — organized by topic."
>
  <StructuredData
    type="breadcrumb"
    data={{
      breadcrumbs: [
        { name: 'Home', url: 'https://hobbinomicon.com/' },
        { name: 'Videos', url: 'https://hobbinomicon.com/videos/' },
      ],
    }}
  />
  <Header theme="light" />

  <main id="main-content" class="min-h-screen bg-parchment dark:bg-parchment-dark">
    <PageHeader
      title="Videos"
      description="Deep dives, painting and terrain tutorials, and indie game coverage, organized by topic."
      breadcrumbs={[{ label: 'Videos', href: '/videos' }]}
    />

    <ContentContainer class="py-8 space-y-16">
      {collections.map((c) => (
        <section>
          <div class="flex items-end justify-between gap-4 mb-2">
            <h2 class="text-2xl md:text-3xl font-heading font-bold text-ink dark:text-ink-dark">
              <a href={`/videos/${c.slug}/`} class="hover:underline underline-offset-4">{c.title}</a>
            </h2>
            <a href={`/videos/${c.slug}/`} class="text-ink/70 dark:text-ink-dark/70 hover:text-ink dark:hover:text-ink-dark text-sm font-medium whitespace-nowrap">
              View all {c.posts.length} →
            </a>
          </div>
          <p class="text-ink/70 dark:text-ink-dark/70 mb-6 max-w-2xl">
            {c.description}
            {c.playlistUrl && (
              <>
                {' '}
                <a href={`${c.playlistUrl}?${utm}`} target="_blank" rel="noopener noreferrer" class="underline hover:no-underline whitespace-nowrap">
                  Watch the playlist on YouTube →
                </a>
              </>
            )}
          </p>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            {c.posts.slice(0, 3).map((post) => <VideoCard post={post} />)}
          </div>
        </section>
      ))}

      {archiveCount > 0 && (
        <section class="border-t border-ink/10 dark:border-ink-dark/10 pt-10 text-center">
          <p class="text-ink/70 dark:text-ink-dark/70 mb-2">
            Looking for the day-to-day stuff? Mail days, progress fragments, and the rest of the back catalogue.
          </p>
          <a href="/videos/archive/" class="text-ink dark:text-ink-dark font-medium underline underline-offset-4 hover:no-underline">
            Browse the full archive ({archiveCount}) →
          </a>
        </section>
      )}
    </ContentContainer>

    <Footer />
  </main>
</BaseLayout>
