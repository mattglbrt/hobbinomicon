---
// Layout
import BaseLayout from "@/layouts/BaseLayout.astro";
// Fundation
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
---

<BaseLayout>
  <section>
    <Wrapper variant="heroNarrow">
      <Text
        tag="h1"
        variant="displaySM"
        class="text-base-900 font-medium 2xl:text-5xl tracking-tight"
      >
        Who we are
      </Text>
      <Text
        tag="p"
        variant="textBase"
        class="mt-4 text-base-500 text-balance 2xl:text-xl"
      >
       What is the Hobbinomicon?
      </Text>
    </Wrapper>
  </section>
  <section>
    <Wrapper variant="narrow" class="py-6">
      <div class="flex flex-col gap-4 text-base-500">
        <Text tag="p" variant="textBase">
          The Hobbinomicon is a directory dedicated to the world of tabletop gaming, wargames, and scale modeling. 
          Our goal is to serve as a hub for newcomers and long time hobbyists to find and play games they will love.
        </Text>

      </div>
      <div class="mt-24 text-right">
        <Text
          tag="p"
          variant="textBase"
          class="text-base-500 italic"
        >
          "Find it. Learn it. Play it."
        </Text>
        <Text
          tag="p"
          variant="textBase"
          class="text-base-900 mt-2∏ font-semibold"
        >
          — The Hobbinomicon
        </Text>
      </div>
      
    </Wrapper>
  </section>
</BaseLayout>
