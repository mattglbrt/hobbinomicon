---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import HeroHeader from '../components/HeroHeader.astro';
import StatCounter from '../components/StatCounter.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';
import youtubeStats from '../data/youtube-stats.json';

// Manual counters - update these as needed
const miniaturesPainted = 30;
const xactoBlades = 17;
const plasticGlueBottles = 5;
const superGlueBottles = 10;
const toadsShipped = 2;

// Get all published blog posts
const allPosts = await getCollection('blog', ({ data }) => !data.draft);

// Count total posts
const totalPosts = allPosts.length;

// Total videos comes from src/data/youtube-stats.json — refreshed on every
// build by scripts/update-youtube-stats.js (run in `prebuild`), so the daily
// Netlify rebuild keeps it current via the YouTube Data API.
const totalVideos = youtubeStats.videoCount;

// Calculate days since content creation started (September 11, 2025 EST)
const startDate = new Date('2025-09-11T00:00:00-05:00');
const now = new Date(new Date().toLocaleString('en-US', { timeZone: 'America/New_York' }));
const daysSinceStart = Math.floor((now.getTime() - startDate.getTime()) / (1000 * 60 * 60 * 24)) + 1;

// The YouTube network. The daily vlog is the flagship-feed home base, so it
// stays the primary subscribe button; the rest are listed below it.
const youtubeChannels = [
  {
    name: "The Hobbinomicon — Daily Hobby Vlog",
    handle: "Hobbinomicon",
    description: "Daily behind-the-scenes of whatever's on the workbench — painting, builds, and works in progress.",
  },
  {
    name: "The Hobbinomicon",
    handle: "TheHobbinomicon",
    description: "The flagship: high-production deep dives on indie tabletop games — how to play, reviews, painting, and board builds.",
  },
  {
    name: "The Hobbinomicon: Warmachine",
    handle: "TheHobbinomiconWarmachine",
    description: "All things Warmachine — painting, play, news, and live streams.",
  },
  {
    name: "The Hobbinomicon: KDM",
    handle: "TheHobbinomiconKDM",
    description: "Kingdom Death: Monster, edited like an old-school dungeon-crawler RPG.",
  },
  {
    name: "Alone in the Dungeon",
    handle: "AloneInTheDungeon",
    description: "Solo wargames, solo tabletop, and solo TTRPG live plays.",
  },
];
---

<BaseLayout
  title="About | The Hobbinomicon"
  description="What The Hobbinomicon is, why I'm building it, and what I'm trying to do with a hobby directory for the niche of the niche."
>
  <Header theme="light" />

  <main id="main-content" class="min-h-screen bg-parchment dark:bg-parchment-dark">
    <HeroHeader
      title="About The Hobbinomicon"
      subtitle="Hobbying from the deep end of the dungeon."
      backLink={{ href: "/", text: "Back to Home" }}
    />

    <!-- Main Content -->
    <article class="max-w-4xl mx-auto px-6 py-16 md:py-24">
      <!-- Introduction -->
      <div class="prose prose-lg max-w-none mb-16">
        <p class="text-2xl md:text-3xl text-ink dark:text-ink-dark font-serif leading-relaxed mb-8 first-letter:text-6xl first-letter:font-heading first-letter:font-bold first-letter:float-left first-letter:mr-3 first-letter:leading-none first-letter:mt-1">
          The Hobbinomicon is part journal, part personal hobby log, part indie game directory and discovery platform.
        </p>
        <p class="text-2xl md:text-3xl text-ink dark:text-ink-dark font-serif leading-relaxed mb-8">
          I'm not chasing a big audience. I'm trying to build the site I wanted when I was hunting down Mage Knight strategy guides on websites that had been dead for a decade. If you're looking for indie games, weird minis, or games that put the soul back into gaming and hobbying, this site is for you.
        </p>
        <p class="text-2xl md:text-3xl text-ink dark:text-ink-dark font-serif leading-relaxed mb-8">
          I want to help people find indie games or specialist games their publishers (Games Workshop) abandoned. I want to highlight the indie and small press studios that are making great games and keeping the hobby alive. The people doing it for the love of the game.
        </p>
        <p class="text-2xl md:text-3xl text-ink dark:text-ink-dark font-serif leading-relaxed">
          Daily hobby content since September 2025 and haven't missed a day yet. Working toward a Golden Daemon win and, some day, my own miniature company. Hopefully.
        </p>
        <p class="text-xl md:text-2xl text-ink dark:text-ink-dark font-serif leading-relaxed mt-8">
          Check out my <a href="/buy-sell-trade/" class="underline hover:text-ink/70 dark:hover:text-ink-dark/70 transition-colors">buy / sell / trade list</a> if you're looking to swap hobby items.
        </p>
      </div>

      <!-- Stats Counters -->
      <section class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-16">
        <StatCounter value={daysSinceStart > 0 ? daysSinceStart : 0} label="Day Hobby Streak" />
        <StatCounter value={totalPosts} label="Posts Published" singularLabel="Post Published" />
        <StatCounter value={totalVideos} label="Videos Created" singularLabel="Video Created" />
        <StatCounter value={miniaturesPainted} label="Minis Painted" singularLabel="Mini Painted" />
        <StatCounter value={xactoBlades} label="Xacto Blades" singularLabel="Xacto Blade" />
        <StatCounter value={plasticGlueBottles} label="Plastic Glue Bottles" singularLabel="Plastic Glue Bottle" />
        <StatCounter value={superGlueBottles} label="Super Glue Bottles" singularLabel="Super Glue Bottle" />
        <StatCounter value={toadsShipped} label="Toads Shipped" singularLabel="Toad Shipped" />
      </section>

      <!-- Events & Competitions -->
      <section class="mb-16">
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-ink dark:text-ink-dark mb-8">
          Events & Competitions
        </h2>
        <div class="space-y-4">
          <div class="bg-ink/5 dark:bg-ink-dark/10 rounded-lg p-6 border-l-4 border-ink/30 dark:border-ink-dark/30">
            <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-2 mb-3">
              <h3 class="text-xl font-heading font-bold text-ink dark:text-ink-dark">
                Children of Gomb: Hobgoblin Community Challenge
              </h3>
              <span class="text-sm text-ink/60 dark:text-ink-dark/60 font-medium">
                March 2026
              </span>
            </div>
            <p class="text-ink/70 dark:text-ink-dark/70 mb-2">
              Online · Hobgoblin
            </p>
            <p class="text-ink dark:text-ink-dark mb-4">
              Custom daemon prince sculpt built from a miscast resin body with full green stuff conversion. First real sculpting project.
            </p>
            <div class="flex flex-wrap gap-2">
              <a href="/blog/starting-my-entry-for-children-of-gomb/" class="text-sm px-3 py-1 bg-ink/10 dark:bg-ink-dark/20 text-ink dark:text-ink-dark rounded-full hover:bg-ink/20 dark:hover:bg-ink-dark/30 transition-colors">
                Starting the Entry
              </a>
              <a href="/blog/starting-my-first-sculpting-project/" class="text-sm px-3 py-1 bg-ink/10 dark:bg-ink-dark/20 text-ink dark:text-ink-dark rounded-full hover:bg-ink/20 dark:hover:bg-ink-dark/30 transition-colors">
                First Sculpting Project
              </a>
              <a href="/blog/sculpting-toes/" class="text-sm px-3 py-1 bg-ink/10 dark:bg-ink-dark/20 text-ink dark:text-ink-dark rounded-full hover:bg-ink/20 dark:hover:bg-ink-dark/30 transition-colors">
                Sculpting Toes
              </a>
              <a href="/blog/more-daemon-prince-progress/" class="text-sm px-3 py-1 bg-ink/10 dark:bg-ink-dark/20 text-ink dark:text-ink-dark rounded-full hover:bg-ink/20 dark:hover:bg-ink-dark/30 transition-colors">
                More Progress
              </a>
              <a href="/blog/finishing-the-daemon-prince-and-mail-day/" class="text-sm px-3 py-1 bg-ink/10 dark:bg-ink-dark/20 text-ink dark:text-ink-dark rounded-full hover:bg-ink/20 dark:hover:bg-ink-dark/30 transition-colors">
                Finishing the Sculpt
              </a>
              <a href="/blog/painting-creepy-cartoonish-skin/" class="text-sm px-3 py-1 bg-ink/10 dark:bg-ink-dark/20 text-ink dark:text-ink-dark rounded-full hover:bg-ink/20 dark:hover:bg-ink-dark/30 transition-colors">
                Painting Skin
              </a>
              <a href="/blog/more-progress-on-the-children-of-gomb-entry/" class="text-sm px-3 py-1 bg-ink/10 dark:bg-ink-dark/20 text-ink dark:text-ink-dark rounded-full hover:bg-ink/20 dark:hover:bg-ink-dark/30 transition-colors">
                Painting Chain
              </a>
              <a href="/blog/painting-chaosy-green-marble/" class="text-sm px-3 py-1 bg-ink/10 dark:bg-ink-dark/20 text-ink dark:text-ink-dark rounded-full hover:bg-ink/20 dark:hover:bg-ink-dark/30 transition-colors">
                Green Marble
              </a>
              <a href="/blog/i-finished-the-daemon-prince/" class="text-sm px-3 py-1 bg-ink/10 dark:bg-ink-dark/20 text-ink dark:text-ink-dark rounded-full hover:bg-ink/20 dark:hover:bg-ink-dark/30 transition-colors">
                Finished Entry
              </a>
            </div>
          </div>
          <div class="bg-ink/5 dark:bg-ink-dark/10 rounded-lg p-6 border-l-4 border-amber-500">
            <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-2 mb-3">
              <h3 class="text-xl font-heading font-bold text-ink dark:text-ink-dark">
                Winter Wonderland at Atlantis
              </h3>
              <span class="text-sm text-ink/60 dark:text-ink-dark/60 font-medium">
                December 7, 2025
              </span>
            </div>
            <p class="text-ink/70 dark:text-ink-dark/70 mb-2">
              Portsmouth, VA
            </p>
            <p class="text-ink dark:text-ink-dark mb-4">
              Won ~$60 in store credit for my Butcher and The Love Shack entries.
            </p>
            <div class="flex flex-wrap gap-2">
              <a href="/blog/warmachine-winter-wonderland-event-photos/" class="text-sm px-3 py-1 bg-ink/10 dark:bg-ink-dark/20 text-ink dark:text-ink-dark rounded-full hover:bg-ink/20 dark:hover:bg-ink-dark/30 transition-colors">
                Event Recap
              </a>
              <a href="/blog/painting-butcher-klaus-minicrate/" class="text-sm px-3 py-1 bg-ink/10 dark:bg-ink-dark/20 text-ink dark:text-ink-dark rounded-full hover:bg-ink/20 dark:hover:bg-ink-dark/30 transition-colors">
                Painting Butcher Klaus
              </a>
              <a href="/blog/the-best-snow-effect-ever/" class="text-sm px-3 py-1 bg-ink/10 dark:bg-ink-dark/20 text-ink dark:text-ink-dark rounded-full hover:bg-ink/20 dark:hover:bg-ink-dark/30 transition-colors">
                Snow Effect
              </a>
              <a href="/blog/finishing-paint-on-the-shack/" class="text-sm px-3 py-1 bg-ink/10 dark:bg-ink-dark/20 text-ink dark:text-ink-dark rounded-full hover:bg-ink/20 dark:hover:bg-ink-dark/30 transition-colors">
                Painting The Shack
              </a>
              <a href="/blog/how-to-paint-wood/" class="text-sm px-3 py-1 bg-ink/10 dark:bg-ink-dark/20 text-ink dark:text-ink-dark rounded-full hover:bg-ink/20 dark:hover:bg-ink-dark/30 transition-colors">
                How to Paint Wood
              </a>
            </div>
          </div>
          <div class="bg-ink/5 dark:bg-ink-dark/10 rounded-lg p-6 border-l-4 border-ink/30 dark:border-ink-dark/30">
            <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-2 mb-3">
              <h3 class="text-xl font-heading font-bold text-ink dark:text-ink-dark">
                Trench Crusade Campaign Conclusion
              </h3>
              <span class="text-sm text-ink/60 dark:text-ink-dark/60 font-medium">
                November 25, 2025
              </span>
            </div>
            <p class="text-ink/70 dark:text-ink-dark/70 mb-2">
              Portsmouth, VA
            </p>
            <div class="flex flex-wrap gap-2">
              <a href="/blog/two-minute-trench-crusade-battle-recap/" class="text-sm px-3 py-1 bg-ink/10 dark:bg-ink-dark/20 text-ink dark:text-ink-dark rounded-full hover:bg-ink/20 dark:hover:bg-ink-dark/30 transition-colors">
                Battle Recap
              </a>
              <a href="/blog/building-more-figures-for-trench-crusade/" class="text-sm px-3 py-1 bg-ink/10 dark:bg-ink-dark/20 text-ink dark:text-ink-dark rounded-full hover:bg-ink/20 dark:hover:bg-ink-dark/30 transition-colors">
                Building Figures
              </a>
              <a href="/blog/how-to-paint-trench-crusade-communicant/" class="text-sm px-3 py-1 bg-ink/10 dark:bg-ink-dark/20 text-ink dark:text-ink-dark rounded-full hover:bg-ink/20 dark:hover:bg-ink-dark/30 transition-colors">
                Painting Communicant
              </a>
              <a href="/blog/how-to-paint-trench-pilgrims-fast/" class="text-sm px-3 py-1 bg-ink/10 dark:bg-ink-dark/20 text-ink dark:text-ink-dark rounded-full hover:bg-ink/20 dark:hover:bg-ink-dark/30 transition-colors">
                Painting Pilgrims Fast
              </a>
              <a href="/blog/my-favorite-bases-for-trench-crusade/" class="text-sm px-3 py-1 bg-ink/10 dark:bg-ink-dark/20 text-ink dark:text-ink-dark rounded-full hover:bg-ink/20 dark:hover:bg-ink-dark/30 transition-colors">
                Favorite Bases
              </a>
              <a href="/blog/paint-a-trench-pilgrim-warband-in-2-hours/" class="text-sm px-3 py-1 bg-ink/10 dark:bg-ink-dark/20 text-ink dark:text-ink-dark rounded-full hover:bg-ink/20 dark:hover:bg-ink-dark/30 transition-colors">
                Warband in 2 Hours
              </a>
              <a href="/blog/revisiting-trench-crusade-warband/" class="text-sm px-3 py-1 bg-ink/10 dark:bg-ink-dark/20 text-ink dark:text-ink-dark rounded-full hover:bg-ink/20 dark:hover:bg-ink-dark/30 transition-colors">
                Revisiting Warband
              </a>
              <a href="/blog/trench-crusade-bases-weathering-finishing-our-warband-part-1/" class="text-sm px-3 py-1 bg-ink/10 dark:bg-ink-dark/20 text-ink dark:text-ink-dark rounded-full hover:bg-ink/20 dark:hover:bg-ink-dark/30 transition-colors">
                Bases & Weathering
              </a>
            </div>
          </div>
        </div>
      </section>

      <!-- YouTube CTA Section -->
      <section class="bg-ink dark:bg-ink text-white p-12 md:p-16 rounded-lg text-center">
        <div class="mb-8">
          <svg class="w-20 h-20 mx-auto text-white opacity-80" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
        </div>
        <h2 class="text-4xl md:text-6xl font-heading font-bold mb-6">
          Join me in the Dungeon
        </h2>
        <p class="text-xl md:text-2xl text-white/90 mb-10 leading-relaxed max-w-2xl mx-auto">
          A whole network of channels for painting tutorials, hobby vlogs, deep dives, battle reports, and solo play.
        </p>

        <!-- Channel network -->
        <div class="grid gap-4 sm:grid-cols-2 text-left max-w-3xl mx-auto">
          {youtubeChannels.map((channel) => (
            <a
              href={`https://www.youtube.com/@${channel.handle}`}
              target="_blank"
              rel="noopener noreferrer"
              class="group flex flex-col gap-2 p-5 rounded-lg bg-white/5 border border-white/10 hover:bg-white/10 hover:border-white/25 transition-all"
            >
              <div class="flex items-start gap-3">
                <svg class="w-6 h-6 shrink-0 text-[#ff0000]" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                </svg>
                <div>
                  <h3 class="font-heading font-bold text-white leading-tight">{channel.name}</h3>
                  <span class="text-sm text-white/50">@{channel.handle}</span>
                </div>
              </div>
              <p class="text-sm text-white/80 leading-relaxed">{channel.description}</p>
              <span class="mt-1 text-sm font-heading font-bold text-white/90 group-hover:text-white inline-flex items-center gap-1">
                Subscribe
                <span class="transition-transform group-hover:translate-x-0.5" aria-hidden="true">→</span>
              </span>
            </a>
          ))}
        </div>

        <p class="text-sm text-white/60 mt-8">
          New videos every day
        </p>
      </section>
    </article>

    <Footer />
  </main>
</BaseLayout>
