---
/**
 * Search Modal Component
 * Keyboard-navigable search with filters and accessibility.
 *
 * Querying is powered by Pagefind: a static, build-time, full-text index
 * (post bodies and transcripts included) generated by the `postbuild` step
 * (`pagefind --site dist`) and loaded lazily from /pagefind/pagefind.js.
 * Pages opt into indexing via `data-pagefind-body` in the content layouts,
 * with `data-pagefind-meta`/`data-pagefind-filter` supplying title/category/tags.
 *
 * This frontmatter only builds the SSR filter chips and the default browse
 * surface (featured games / latest news / recent vlogs). Pagefind is not
 * available under `astro dev` — test search with `npm run build && npm run preview`.
 */
import { getCollection } from 'astro:content';
import { getPublishedPosts, groupByTags } from '../utils/collections';
import { getTagDisplay } from '../utils/tags';

const allPosts = await getCollection('blog');
const publishedPosts = getPublishedPosts(allPosts);

const allProjects = await getCollection('projects');
const publishedProjects = allProjects.filter((p) => !p.data.draft);

const games = await getCollection('games', ({ data }) => !data.draft);
const studios = await getCollection('studios', ({ data }) => !data.draft);
const people = await getCollection('people', ({ data }) => !data.draft);
const news = await getCollection('news', ({ data }) => !data.draft);

// Filter chip labels: directory pillars first, then blog categories.
const blogCategories = [...new Set(publishedPosts.map((post) => post.data.category))].sort();
const directoryCategories = [
  games.length ? 'Games' : null,
  news.length ? 'Indie News' : null,
  studios.length ? 'Studios' : null,
  people.length ? 'People' : null,
  publishedProjects.length ? 'Projects' : null,
].filter((c): c is string => Boolean(c));
const categories = [...new Set([...directoryCategories, ...blogCategories])];

// Top tags by blog usage (densest source). Per-item tags from games/news still
// participate in filtering when their result row surfaces them as chips.
const tagsMap = groupByTags(publishedPosts);
const topTags = Array.from(tagsMap.entries())
  .sort((a, b) => b[1].length - a[1].length)
  .slice(0, 8)
  .map(([tag]) => ({ tag, display: getTagDisplay(tag) }));

// Default browse surface: shown when the modal opens with no query and no
// filters. Mixes recent news, featured games, and latest vlogs so visitors
// who don't know what to type still have a clickable starting point.
const browseNews = [...news]
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
const browseGames = [...games]
  .sort((a, b) => {
    if (a.data.tier !== b.data.tier) return a.data.tier === 'indie' ? -1 : 1;
    const aDate = (a.data.updatedDate || a.data.pubDate).valueOf();
    const bDate = (b.data.updatedDate || b.data.pubDate).valueOf();
    return bDate - aDate;
  })
  .slice(0, 3);
const browseVlogs = [...publishedPosts]
  .filter((p) => p.data.category === 'Vlogs')
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<style>
  .glass-modal {
    background: rgba(26, 22, 20, 0.85);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow:
      0 25px 50px -12px rgba(0, 0, 0, 0.5),
      inset 0 1px 0 rgba(255, 255, 255, 0.1);
  }

  .glass-input {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    transition: all 0.2s ease;
  }

  .glass-input:focus {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.25);
    box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.1);
  }

  .glass-input::placeholder {
    color: rgba(255, 255, 255, 0.4);
  }

  .result-item {
    transition: all 0.15s ease;
  }

  .result-item:hover,
  .result-item.selected {
    background: rgba(255, 255, 255, 0.08);
  }

  .glass-kbd {
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .glass-tag {
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .glass-footer {
    background: rgba(255, 255, 255, 0.03);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .filter-chip {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    transition: all 0.15s ease;
  }

  .filter-chip:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.2);
  }

  .filter-chip.active {
    background: rgba(255, 255, 255, 0.15);
    border-color: rgba(255, 255, 255, 0.3);
  }

  /* Custom scrollbar for results */
  #search-results::-webkit-scrollbar {
    width: 6px;
  }

  #search-results::-webkit-scrollbar-track {
    background: transparent;
  }

  #search-results::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.2);
    border-radius: 3px;
  }

  #search-results::-webkit-scrollbar-thumb:hover {
    background: rgba(255, 255, 255, 0.3);
  }
</style>

<!-- Search Modal -->
<div
  id="search-modal"
  class="fixed inset-0 z-[100] hidden"
  role="dialog"
  aria-modal="true"
  aria-labelledby="search-modal-title"
>
  <!-- Backdrop -->
  <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" data-search-backdrop></div>

  <!-- Modal Content -->
  <div class="relative flex items-start justify-center pt-[10vh] px-4">
    <div class="w-full max-w-2xl glass-modal rounded-2xl overflow-hidden">
      <!-- Search Header -->
      <div class="p-4 pb-2">
        <label for="search-input" id="search-modal-title" class="sr-only">Search the Hobbinomicon</label>
        <div class="relative">
          <svg
            class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-white/60"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <input
            type="text"
            id="search-input"
            class="w-full pl-12 pr-20 py-3.5 glass-input rounded-xl text-white text-base focus:outline-none"
            placeholder="Search games, vlogs, news, studios, people..."
            autocomplete="off"
            autocapitalize="off"
            spellcheck="false"
          />
          <kbd class="absolute right-4 top-1/2 -translate-y-1/2 hidden sm:inline-block px-2 py-1 text-xs font-mono glass-kbd text-white/70 rounded-lg">ESC</kbd>
        </div>
      </div>

      <!-- Filters -->
      <div class="px-4 pb-3">
        <!-- Category Filters -->
        <div class="flex flex-wrap gap-2 mb-2">
          <button
            type="button"
            class="filter-chip px-3 py-1 rounded-full text-xs text-white/80 active"
            data-filter-category=""
          >
            All
          </button>
          {categories.map(category => (
            <button
              type="button"
              class="filter-chip px-3 py-1 rounded-full text-xs text-white/80"
              data-filter-category={category}
            >
              {category}
            </button>
          ))}
        </div>

        <!-- Tag Filters -->
        <div class="flex flex-wrap gap-2">
          {topTags.map(({ tag, display }) => (
            <button
              type="button"
              class="filter-chip px-2.5 py-0.5 rounded-full text-xs text-white/60"
              data-filter-tag={tag}
            >
              #{display}
            </button>
          ))}
        </div>
      </div>

      <!-- Search Results -->
      <div id="search-results" class="max-h-[50vh] overflow-y-auto">
        <!-- Result count (hidden until a query/filter is active) -->
        <div id="search-count" class="hidden px-4 pt-3 text-[10px] uppercase tracking-[0.2em] text-white/40 font-heading" aria-live="polite"></div>
        <!-- Default browse surface — shown when there's no query and no filter -->
        <div id="search-empty" class="py-2">
          {browseGames.length > 0 && (
            <div class="px-4 pt-3 pb-1">
              <div class="text-[10px] uppercase tracking-[0.2em] text-white/40 font-heading">Featured games</div>
            </div>
            <ul class="mb-2">
              {browseGames.map((game) => (
                <li>
                  <a href={`/games/${game.id}/`} class="block px-4 py-2 result-item">
                    <div class="font-medium text-white/90">{game.data.title}</div>
                    <div class="text-xs text-white/60 line-clamp-1">{game.data.description}</div>
                  </a>
                </li>
              ))}
            </ul>
          )}
          {browseNews.length > 0 && (
            <div class="px-4 pt-3 pb-1">
              <div class="text-[10px] uppercase tracking-[0.2em] text-white/40 font-heading">Latest news</div>
            </div>
            <ul class="mb-2">
              {browseNews.map((item) => (
                <li>
                  <a href={`/news/${item.id}/`} class="block px-4 py-2 result-item">
                    <div class="font-medium text-white/90">{item.data.title}</div>
                    <div class="text-xs text-white/60 line-clamp-1">{item.data.description}</div>
                  </a>
                </li>
              ))}
            </ul>
          )}
          {browseVlogs.length > 0 && (
            <div class="px-4 pt-3 pb-1">
              <div class="text-[10px] uppercase tracking-[0.2em] text-white/40 font-heading">Recent vlogs</div>
            </div>
            <ul class="mb-2">
              {browseVlogs.map((post) => (
                <li>
                  <a href={`/blog/${post.id}/`} class="block px-4 py-2 result-item">
                    <div class="font-medium text-white/90">{post.data.title}</div>
                    <div class="text-xs text-white/60 line-clamp-1">{post.data.description}</div>
                  </a>
                </li>
              ))}
            </ul>
          )}
        </div>

        <!-- Loading state -->
        <div id="search-loading" class="hidden p-8 text-center" aria-hidden="true">
          <div class="inline-block w-5 h-5 rounded-full border-2 border-white/20 border-t-white/70 animate-spin"></div>
          <p class="text-sm mt-3 text-white/50">Searching…</p>
        </div>

        <!-- No results state -->
        <div id="search-no-results" class="hidden p-8 text-center">
          <p class="text-lg text-white/70">No results for <span data-noresult-query class="text-white/90 font-medium"></span></p>
          <p class="text-sm mt-2 text-white/50">We might not cover it yet. Browse the directory or send us a tip.</p>
          <div class="flex items-center justify-center gap-2 mt-4 flex-wrap">
            <a href="/games/" class="filter-chip px-4 py-1.5 rounded-full text-xs text-white/80">Browse all games</a>
            <a href="/games/skirmish/" class="filter-chip px-4 py-1.5 rounded-full text-xs text-white/80">Skirmish games</a>
            <a href="/contact/" class="filter-chip px-4 py-1.5 rounded-full text-xs text-white/80">Suggest a game</a>
          </div>
        </div>

        <!-- Results list -->
        <ul id="search-results-list" class="hidden" role="listbox">
        </ul>

        <!-- Load next page of results -->
        <div id="search-more" class="hidden p-3 text-center">
          <button type="button" class="filter-chip px-4 py-1.5 rounded-full text-xs text-white/80">
            Show more results
          </button>
        </div>
      </div>

      <!-- Footer -->
      <div class="glass-footer p-3">
        <div class="flex items-center justify-between text-xs text-white/60">
          <div class="flex items-center gap-4">
            <span class="flex items-center gap-1.5">
              <kbd class="px-1.5 py-0.5 glass-kbd rounded text-white/70">↑</kbd>
              <kbd class="px-1.5 py-0.5 glass-kbd rounded text-white/70">↓</kbd>
              <span>navigate</span>
            </span>
            <span class="flex items-center gap-1.5">
              <kbd class="px-1.5 py-0.5 glass-kbd rounded text-white/70">↵</kbd>
              <span>select</span>
            </span>
          </div>
          <button
            type="button"
            class="text-white/60 hover:text-white/70 transition-colors"
            data-search-close
          >
            Close
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Search index loaded on demand when modal opens -->

<script is:inline>
(function() {
  // Only initialize once
  if (window.searchInitialized) return;
  window.searchInitialized = true;

  function initSearch() {
    const modal = document.getElementById('search-modal');
    const input = document.getElementById('search-input');
    const resultsContainer = document.getElementById('search-results');
    const resultsList = document.getElementById('search-results-list');
    const emptyState = document.getElementById('search-empty');
    const noResultsState = document.getElementById('search-no-results');
    const loadingState = document.getElementById('search-loading');
    const noResultQuery = document.querySelector('[data-noresult-query]');
    const countEl = document.getElementById('search-count');
    const moreEl = document.getElementById('search-more');
    const moreBtn = moreEl ? moreEl.querySelector('button') : null;
    const backdrop = document.querySelector('[data-search-backdrop]');
    const closeBtn = document.querySelector('[data-search-close]');
    const categoryFilters = document.querySelectorAll('[data-filter-category]');
    const tagFilters = document.querySelectorAll('[data-filter-tag]');

    if (!modal || !input || !resultsList) return;

    let selectedIndex = -1;
    let results = [];      // genuine (relevance-gated) result rows, rendered
    let allResults = [];   // Pagefind result handles for the whole match set
    let rawLoaded = 0;     // how many raw Pagefind results we've fetched data for
    let activeCategory = '';
    let activeTags = new Set();
    const PAGE_SIZE = 15;

    // Entity pinning: on a name/alias match, float the directory entity (game,
    // studio, person) to the top as a distinct "best match". compact() strips
    // spacing/punctuation so "relic blade" and "Relicblade" compare equal.
    let lastQuery = '';
    const ENTITY_CATS = ['Games', 'Studios', 'People'];
    function compact(s) { return (s || '').toLowerCase().replace(/[^a-z0-9]+/g, ''); }

    // Pagefind is the search engine: a static, build-time, full-text index
    // (transcripts and post bodies included) with typo tolerance and ranking.
    // Loaded lazily on first modal open from /pagefind/pagefind.js.
    var pagefind = null;
    var pagefindReady = null;
    var queryToken = 0;
    function loadPagefind() {
      if (pagefindReady) return pagefindReady;
      pagefindReady = import('/pagefind/pagefind.js').then(function(mod) {
        pagefind = mod;
        if (pagefind.options) pagefind.options({ excerptLength: 30 });
        return pagefind.init ? pagefind.init() : null;
      }).catch(function(err) {
        // Absent in `astro dev` (only generated by a production build).
        pagefind = null;
        console.warn('Pagefind unavailable — run a production build (npm run build):', err);
      });
      return pagefindReady;
    }

    function openModal() {
      modal.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
      loadPagefind();
      // Focus synchronously — the modal is already visible (plain class
      // toggle, no animation), and a delayed focus drops keystrokes typed
      // right after Cmd+K.
      input.focus();
    }

    function closeModal() {
      modal.classList.add('hidden');
      document.body.style.overflow = '';
      input.value = '';
      selectedIndex = -1;
      results = [];
      allResults = [];
      activeCategory = '';
      activeTags.clear();
      resetFilters();
      showEmptyState();
    }

    function resetFilters() {
      categoryFilters.forEach(function(btn) {
        btn.classList.toggle('active', btn.dataset.filterCategory === '');
      });
      tagFilters.forEach(function(btn) {
        btn.classList.remove('active');
      });
    }

    function showEmptyState() {
      emptyState.classList.remove('hidden');
      noResultsState.classList.add('hidden');
      loadingState.classList.add('hidden');
      resultsList.classList.add('hidden');
      countEl.classList.add('hidden');
      moreEl.classList.add('hidden');
    }

    function showLoading() {
      emptyState.classList.add('hidden');
      noResultsState.classList.add('hidden');
      loadingState.classList.remove('hidden');
      resultsList.classList.add('hidden');
      countEl.classList.add('hidden');
      moreEl.classList.add('hidden');
    }

    function showNoResults() {
      if (noResultQuery) noResultQuery.textContent = lastQuery ? '“' + lastQuery + '”' : 'that';
      emptyState.classList.add('hidden');
      noResultsState.classList.remove('hidden');
      loadingState.classList.add('hidden');
      resultsList.classList.add('hidden');
      countEl.classList.add('hidden');
      moreEl.classList.add('hidden');
    }

    function showResults() {
      emptyState.classList.add('hidden');
      noResultsState.classList.add('hidden');
      loadingState.classList.add('hidden');
      resultsList.classList.remove('hidden');
      countEl.classList.remove('hidden');
      updateCountAndMore();
    }

    function updateCountAndMore() {
      var shown = results.length;
      countEl.textContent = shown === 1 ? '1 result' : shown + ' results';
      // Offer "show more" only while raw Pagefind results remain to sift.
      moreEl.classList.toggle('hidden', rawLoaded >= allResults.length);
    }

    function buildFilters() {
      // Both dimensions are native Pagefind filters. `all` gives tag chips AND
      // semantics (every selected tag must match) across the full match set.
      var f = {};
      if (activeCategory) f.category = activeCategory;
      if (activeTags.size > 0) f.tag = { all: Array.from(activeTags) };
      return f;
    }

    function normalizeUrl(url) {
      if (!url) return '/';
      return url.replace(/index\.html$/, '').replace(/\.html$/, '/');
    }

    function metaTitle(it) {
      return (it.meta && it.meta.title) || 'Untitled';
    }

    function metaCategory(it) {
      if (it.meta && it.meta.category) return it.meta.category;
      if (it.filters && it.filters.category && it.filters.category[0]) return it.filters.category[0];
      return '';
    }

    function search(query) {
      var q = (query || '').trim();
      var hasQuery = q.length > 0;
      var hasFilters = activeCategory || activeTags.size > 0;
      lastQuery = q;

      if (!hasQuery && !hasFilters) {
        showEmptyState();
        return;
      }

      // Immediate feedback: show a loading state so the stale browse surface
      // can't be misread as the answer while Pagefind resolves.
      showLoading();

      // Monotonic token guards against out-of-order async responses: a fast
      // keystroke must not have its results overwritten by a slower earlier one.
      var token = ++queryToken;
      loadPagefind().then(function() {
        if (token !== queryToken) return;
        if (!pagefind) { renderEngineError(); return; }
        // A null query with filters set means "everything matching the filters".
        return pagefind.search(hasQuery ? q : null, { filters: buildFilters() });
      }).then(function(res) {
        if (!res || token !== queryToken) return;
        allResults = res.results;
        results = [];
        rawLoaded = 0;
        if (allResults.length === 0) { showNoResults(); return; }
        loadMore(token);
      });
    }

    // Relevance gate: Pagefind returns fuzzy matches for almost any input
    // (e.g. "gaslands" matching "gas"), so a raw miss looks like junk results.
    // Keep only results where the query actually appears in the title,
    // description, or excerpt; if none survive, we fall through to the empty
    // state (a zero-result query is a content request worth capturing).
    function isGenuineMatch(it) {
      var qc = compact(lastQuery);
      if (qc.length < 2) return true; // filter-only browse, or too short to gate
      var excerpt = (it.excerpt || '').replace(/<[^>]+>/g, ' ');
      var hay = compact(metaTitle(it) + ' ' + ((it.meta && it.meta.description) || '') + ' ' + excerpt);
      if (hay.indexOf(qc) !== -1) return true;
      var toks = lastQuery.toLowerCase().split(/\s+/).filter(function(t) { return t.length >= 3; });
      return toks.length > 0 && toks.every(function(t) { return hay.indexOf(compact(t)) !== -1; });
    }

    // Load raw results a page at a time, keeping only genuine matches. If a page
    // is all fuzzy junk, keep pulling until a genuine match appears or the raw
    // set is exhausted (then show the empty state).
    function loadMore(token) {
      var next = allResults.slice(rawLoaded, rawLoaded + PAGE_SIZE);
      Promise.all(next.map(function(r) { return r.data(); })).then(function(items) {
        if (token !== queryToken) return;
        rawLoaded += items.length;
        results = results.concat(items.filter(isGenuineMatch));
        if (results.length === 0) {
          if (rawLoaded >= allResults.length) { showNoResults(); return; }
          loadMore(token);
          return;
        }
        renderResults(results);
        showResults();
        selectedIndex = -1;
      });
    }

    // Float a directory entity (game/studio/person) whose name or alias matches
    // the query to the top, flagged as the best match. On a directory site the
    // entity IS the answer, so it should outrank vlogs/articles.
    function pinBestEntity(items) {
      var qc = compact(lastQuery);
      if (qc.length < 3) return;
      var idx = -1;
      for (var i = 0; i < items.length; i++) {
        if (ENTITY_CATS.indexOf(metaCategory(items[i])) === -1) continue;
        var tc = compact(metaTitle(items[i]));
        if (tc && (tc.indexOf(qc) !== -1 || qc.indexOf(tc) !== -1)) { idx = i; break; }
      }
      items.forEach(function(it) { it.__best = false; });
      if (idx > 0) { items.unshift(items.splice(idx, 1)[0]); }
      if (idx !== -1) { items[0].__best = true; }
    }

    function renderResults(items) {
      pinBestEntity(items);
      resultsList.innerHTML = items.map(function(it, index) {
        var tags = ((it.filters && it.filters.tag) || []).slice(0, 3);
        var tagsHtml = tags.map(function(tag) {
          return '<button type="button" class="result-tag text-xs text-white/50 hover:text-white/90 transition-colors" data-result-tag="' + escapeHtml(tag) + '">#' + escapeHtml(tag) + '</button>';
        }).join(' ');
        var cat = metaCategory(it);
        var catHtml = cat ? '<span class="text-xs px-2 py-0.5 glass-tag text-white/60 rounded-lg">' + escapeHtml(cat) + '</span>' : '';
        // Prefer the entity's own curated description over Pagefind's auto
        // excerpt — keeps raw transcript text and harvested page copy out of
        // snippets. Fall back to the (already-<mark>-highlighted) excerpt.
        var snippet = (it.meta && it.meta.description) ? escapeHtml(it.meta.description) : (it.excerpt || '');
        var bestBadge = it.__best ? '<span class="text-[10px] uppercase tracking-[0.15em] px-2 py-0.5 rounded-full bg-white/15 border border-white/25 text-white/90">Best match</span>' : '';
        var rowClass = it.__best ? 'block px-4 py-3 result-item search-result-link bg-white/5 border-l-2 border-white/40' : 'block px-4 py-3 result-item search-result-link';

        return '<li role="option" id="search-result-' + index + '">' +
          '<a href="' + normalizeUrl(it.url) + '" class="' + rowClass + '" data-index="' + index + '">' +
            '<div class="flex items-center gap-2 mb-1">' +
              '<span class="font-medium text-white/90">' + escapeHtml(metaTitle(it)) + '</span>' + bestBadge +
            '</div>' +
            '<div class="text-sm text-white/70 line-clamp-2">' + snippet + '</div>' +
            '<div class="flex items-center gap-2 mt-2 flex-wrap">' + catHtml + tagsHtml + '</div>' +
          '</a>' +
        '</li>';
      }).join('');

      // Wire up clickable tag filters inside each result row. Tags are
      // <button>s nested inside the <a> wrapper so they need preventDefault +
      // stopPropagation to avoid triggering navigation.
      resultsList.querySelectorAll('[data-result-tag]').forEach(function(btn) {
        btn.addEventListener('click', function(e) {
          e.preventDefault();
          e.stopPropagation();
          var tag = btn.dataset.resultTag;
          if (!tag) return;
          activeTags.add(tag);
          tagFilters.forEach(function(b) {
            if (b.dataset.filterTag === tag) b.classList.add('active');
          });
          search(input.value);
          input.focus();
        });
      });
    }

    function renderEngineError() {
      resultsList.innerHTML = '<li class="px-4 py-6 text-center text-sm text-white/60">Search runs on the built site. Try <span class="glass-kbd px-1.5 py-0.5 rounded">npm run build &amp;&amp; npm run preview</span>.</li>';
      emptyState.classList.add('hidden');
      noResultsState.classList.add('hidden');
      resultsList.classList.remove('hidden');
      countEl.classList.add('hidden');
      moreEl.classList.add('hidden');
    }

    function escapeHtml(text) {
      var div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    function updateSelection(newIndex) {
      var items = resultsList.querySelectorAll('li');
      if (items.length === 0) return;

      // Remove previous selection
      items.forEach(function(item) {
        item.querySelector('a').classList.remove('selected');
        item.removeAttribute('aria-selected');
      });

      // Update index
      if (newIndex < 0) newIndex = items.length - 1;
      if (newIndex >= items.length) newIndex = 0;
      selectedIndex = newIndex;

      // Apply new selection
      var selected = items[selectedIndex];
      if (selected) {
        selected.querySelector('a').classList.add('selected');
        selected.setAttribute('aria-selected', 'true');
        selected.scrollIntoView({ block: 'nearest' });
      }
    }

    // Category filter click handlers. Return focus to the input so the footer's
    // "↵ select" stays true (Enter selects a result, not re-toggles the chip).
    categoryFilters.forEach(function(btn) {
      btn.addEventListener('click', function() {
        activeCategory = btn.dataset.filterCategory;
        categoryFilters.forEach(function(b) {
          b.classList.toggle('active', b.dataset.filterCategory === activeCategory);
        });
        search(input.value);
        input.focus();
      });
    });

    // Tag filter click handlers
    tagFilters.forEach(function(btn) {
      btn.addEventListener('click', function() {
        var tag = btn.dataset.filterTag;
        if (activeTags.has(tag)) {
          activeTags.delete(tag);
          btn.classList.remove('active');
        } else {
          activeTags.add(tag);
          btn.classList.add('active');
        }
        search(input.value);
        input.focus();
      });
    });

    // Open triggers are delegated to document: the header lives inside #swup,
    // so Swup replaces the trigger buttons on every navigation — listeners
    // bound directly to them die after the first page swap (the modal itself
    // sits outside #swup and is safe to bind directly).
    document.addEventListener('click', function(e) {
      var el = e.target instanceof Element ? e.target.closest('[data-search-trigger]') : null;
      if (el) openModal();
    });

    backdrop && backdrop.addEventListener('click', closeModal);
    closeBtn && closeBtn.addEventListener('click', closeModal);

    // Close when any result/browse link is clicked. Swup intercepts these
    // links and swaps only #swup — the modal lives outside it, so without
    // this the page changes underneath while the modal stays open. Result
    // tag buttons stopPropagation, so they never reach this handler.
    modal.addEventListener('click', function(e) {
      var link = e.target instanceof Element ? e.target.closest('a[href]') : null;
      if (link) closeModal();
    });
    moreBtn && moreBtn.addEventListener('click', function() { loadMore(queryToken); });

    var debounceTimer;
    input.addEventListener('input', function(e) {
      var val = e.target.value;
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(function() { search(val); }, 120);
    });

    input.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        closeModal();
      } else if (e.key === 'ArrowDown') {
        e.preventDefault();
        updateSelection(selectedIndex + 1);
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        updateSelection(selectedIndex - 1);
      } else if (e.key === 'Enter' && selectedIndex >= 0 && results[selectedIndex]) {
        e.preventDefault();
        // Click the rendered link instead of setting window.location so the
        // navigation goes through Swup (and the modal-close click handler).
        var selectedLink = resultsList.querySelector('[data-index="' + selectedIndex + '"]');
        if (selectedLink) {
          selectedLink.click();
        } else {
          window.location.href = normalizeUrl(results[selectedIndex].url);
        }
      }
    });

    // Global keyboard shortcut (Cmd/Ctrl + K)
    document.addEventListener('keydown', function(e) {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        if (modal.classList.contains('hidden')) {
          openModal();
        } else {
          closeModal();
        }
      }
      if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
        closeModal();
      }
    });
  }

  // Initialize when DOM is ready. The search modal lives outside #swup
  // (rendered once by BaseLayout, content is page-independent), so its DOM
  // is never destroyed by a Swup navigation and this only needs to run once.
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSearch);
  } else {
    initSearch();
  }
})();
</script>
