---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { getHeroImage, isImageMetadata } from '../utils/getHeroImage';
import { getYouTubeFallbackHandler } from '../utils/youtubeImageFallback';

interface Props {
  post: CollectionEntry<'blog'>;
  eager?: boolean;
}

const { post, eager = false } = Astro.props;

const { id, data } = post;
const { title, description, heroImage, heroImageAlt, youtubeId, category } = data;

const displayImage = getHeroImage(heroImage, youtubeId);
const isOptimizedImage = isImageMetadata(displayImage);
const isRemoteImage = !isOptimizedImage && typeof displayImage === 'string' && displayImage.startsWith('http');
---

<style>
  .resource-image img {
    animation: resFadeIn 0.3s ease-in;
  }

  @keyframes resFadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .res-loading {
    backdrop-filter: blur(10px);
    background: linear-gradient(to bottom, #e5d5c1, #d4c4b0);
    transition: opacity 0.3s ease-out;
  }

  .res-loading.loaded {
    opacity: 0;
    pointer-events: none;
  }
</style>

<article class="group">
  <a href={`/blog/${id}`} class="block relative overflow-hidden rounded-lg aspect-[16/9] resource-image hover:-translate-y-1 transition-all duration-300 hover:shadow-xl">
    <!-- Loading placeholder -->
    <div class="absolute inset-0 res-loading" data-placeholder></div>

    <!-- Image fills entire card -->
    {isOptimizedImage ? (
      <Image
        src={displayImage}
        alt={heroImageAlt || title}
        width={640}
        height={360}
        class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
        loading={eager ? 'eager' : 'lazy'}
        decoding="async"
        format="webp"
        quality={65}
        widths={[320, 480, 640]}
        sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 400px"
        onload="this.closest('.resource-image').querySelector('[data-placeholder]').classList.add('loaded')"
      />
    ) : isRemoteImage ? (
      <img
        src={displayImage}
        alt={heroImageAlt || title}
        class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
        loading={eager ? 'eager' : 'lazy'}
        decoding="async"
        width="640"
        height="360"
        data-youtube-id={youtubeId}
        onerror={getYouTubeFallbackHandler('id')}
        onload="this.closest('.resource-image').querySelector('[data-placeholder]').classList.add('loaded')"
      />
    ) : (
      <Image
        src={displayImage}
        alt={heroImageAlt || title}
        width={640}
        height={360}
        class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
        loading={eager ? 'eager' : 'lazy'}
        decoding="async"
        format="webp"
        quality={65}
        widths={[320, 480, 640]}
        sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 400px"
        onload="this.closest('.resource-image').querySelector('[data-placeholder]').classList.add('loaded')"
      />
    )}

    <!-- Gradient overlay -->
    <div class="absolute inset-0 bg-gradient-to-t from-ink via-ink/20 to-transparent opacity-70 group-hover:opacity-90 transition-opacity duration-400"></div>

    <!-- Category badge -->
    <div class="absolute top-3 left-3">
      <span class="inline-block px-2 py-0.5 bg-white/10 backdrop-blur-md text-white/80 text-[0.65rem] font-heading uppercase tracking-[0.15em] rounded border border-white/10">
        {category}
      </span>
    </div>

    <!-- Content at bottom -->
    <div class="absolute bottom-0 left-0 right-0 p-4">
      <h3 class="text-base md:text-lg font-display font-bold text-white leading-tight drop-shadow-lg line-clamp-2">
        {title}
      </h3>
      {description && (
        <p class="text-xs text-white/60 mt-1 line-clamp-1 translate-y-2 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300 hidden md:block">
          {description}
        </p>
      )}
    </div>
  </a>
</article>
