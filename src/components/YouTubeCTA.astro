---
import ContentContainer from './ContentContainer.astro';

interface Props {
  title?: string;
  description?: string;
  channelUrl?: string;
  buttonText?: string;
  subtitle?: string;
}

const {
  title = 'Join me in the Dungeon',
  description = 'Join me on YouTube for painting tutorials, hobby vlogs, battle reports, and to follow my journey to become a Golden Demon winning painter.',
  channelUrl = 'https://www.youtube.com/@Hobbinomicon',
  buttonText = 'Subscribe on YouTube',
  subtitle = 'New videos every day'
} = Astro.props;
---

<section class="bg-ink dark:bg-ink-dark py-20 md:py-32 relative overflow-hidden cursor-spotlight">
  <!-- Oversized YouTube icon watermark -->
  <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
    <svg class="w-[40rem] h-[40rem] text-white/[0.02]" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
      <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
    </svg>
  </div>

  <!-- Decorative line -->
  <div class="max-w-xs mx-auto mb-12">
    <div class="h-px bg-gradient-to-r from-transparent via-white/20 to-transparent"></div>
  </div>

  <ContentContainer maxWidth="4xl" class="text-center relative z-10">
    <h2 class="text-5xl md:text-7xl lg:text-8xl font-display font-bold text-parchment dark:text-parchment-dark mb-6 leading-tight">
      {title}
    </h2>
    <p class="text-lg md:text-xl text-parchment/60 dark:text-parchment-dark/60 mb-10 leading-relaxed max-w-2xl mx-auto font-serif">
      {description}
    </p>
    <a
      href={channelUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-3 px-8 py-4 bg-parchment dark:bg-parchment-dark text-ink dark:text-ink-dark font-heading uppercase tracking-wider text-sm rounded-lg hover:scale-105 transition-all duration-300 shadow-lg"
    >
      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
      </svg>
      {buttonText}
    </a>
    <p class="text-xs text-parchment/40 dark:text-parchment-dark/40 mt-6 font-heading uppercase tracking-[0.2em]">
      {subtitle}
    </p>
  </ContentContainer>

  <!-- Decorative line -->
  <div class="max-w-xs mx-auto mt-12">
    <div class="h-px bg-gradient-to-r from-transparent via-white/20 to-transparent"></div>
  </div>
</section>
