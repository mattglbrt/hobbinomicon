---
// In-prose YouTube embed. Renders the lazy facade (thumbnail + play button)
// rather than a live iframe, so embeds in MDX bodies don't load YouTube's
// player JS/iframe (and its webfonts) on page load — that was tanking LCP/TBT
// and pulling in Roboto from gstatic. The real iframe loads on click.
import LiteYouTube from './LiteYouTube.astro';

interface Props {
  videoId: string;
  title?: string;
}

const { videoId, title = 'YouTube video' } = Astro.props;
---

<div class="my-8">
  <LiteYouTube videoId={videoId} title={title} />
</div>
