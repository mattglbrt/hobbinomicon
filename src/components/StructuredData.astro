---
/**
 * StructuredData Component
 * Renders JSON-LD structured data for SEO.
 * Each `type` corresponds to a schema.org type and accepts its own data shape.
 */

interface WebSiteData {
  siteName?: string;
  siteUrl?: string;
  siteDescription?: string;
}

interface OrganizationData {
  name: string;
  url: string;
  description?: string;
  logo?: string;
  foundingDate?: string;
  address?: string;
  sameAs?: string[];
}

interface BlogPostingData {
  title: string;
  description: string;
  image?: string;
  datePublished: Date;
  dateModified?: Date;
  authorName?: string;
  authorUrl?: string;
  keywords?: string[];
  category?: string;
  wordCount?: number;
  url: string;
}

interface NewsArticleData extends BlogPostingData {
  sourceUrl?: string;
  sourceName?: string;
}

interface BreadcrumbItem {
  name: string;
  url: string;
}

interface BreadcrumbData {
  breadcrumbs: BreadcrumbItem[];
}

interface GameData {
  name: string;
  description: string;
  image?: string;
  url: string;
  datePublished?: Date;
  dateModified?: Date;
  releaseYear?: number;
  publisher?: { name: string; url?: string };
  designers?: { name: string; url?: string }[];
  genre?: string[];
}

interface PersonData {
  name: string;
  description: string;
  image?: string;
  url: string;
  jobTitles?: string[];
  affiliations?: { name: string; url?: string }[];
  sameAs?: string[];
}

interface VideoObjectData {
  name: string;
  description: string;
  thumbnailUrl: string;
  uploadDate: Date;
  youtubeId: string;
}

type Props =
  | { type: 'website'; data: WebSiteData }
  | { type: 'organization'; data: OrganizationData }
  | { type: 'blogPosting'; data: BlogPostingData }
  | { type: 'newsArticle'; data: NewsArticleData }
  | { type: 'breadcrumb'; data: BreadcrumbData }
  | { type: 'game'; data: GameData }
  | { type: 'person'; data: PersonData }
  | { type: 'videoObject'; data: VideoObjectData };

const props = Astro.props as Props;

function buildSchema(): Record<string, unknown> | null {
  switch (props.type) {
    case 'website': {
      const d = props.data;
      return {
        '@type': 'WebSite',
        name: d.siteName || 'The Hobbinomicon',
        url: d.siteUrl || 'https://hobbinomicon.com',
        description: d.siteDescription || 'Hobbying from the deep end of the dungeon. Miniature painting, TTRPGs, and creative projects.',
      };
    }

    case 'organization': {
      const d = props.data;
      return {
        '@type': 'Organization',
        name: d.name,
        url: d.url,
        ...(d.description && { description: d.description }),
        ...(d.logo && { logo: d.logo }),
        ...(d.foundingDate && { foundingDate: d.foundingDate }),
        ...(d.address && { address: d.address }),
        ...(d.sameAs?.length && { sameAs: d.sameAs }),
      };
    }

    case 'blogPosting':
    case 'newsArticle': {
      const d = props.data;
      return {
        '@type': props.type === 'newsArticle' ? 'NewsArticle' : 'BlogPosting',
        headline: d.title,
        description: d.description,
        ...(d.image && { image: d.image }),
        datePublished: d.datePublished.toISOString(),
        dateModified: (d.dateModified ?? d.datePublished).toISOString(),
        author: {
          '@type': 'Person',
          name: d.authorName || 'Hobbinomicon',
          url: d.authorUrl || 'https://hobbinomicon.com/about',
        },
        publisher: {
          '@type': 'Organization',
          name: 'The Hobbinomicon',
          logo: {
            '@type': 'ImageObject',
            url: 'https://hobbinomicon.com/og-image.jpg',
          },
        },
        mainEntityOfPage: {
          '@type': 'WebPage',
          '@id': d.url,
        },
        ...(d.keywords?.length && { keywords: d.keywords }),
        ...(d.category && { articleSection: d.category }),
        ...(d.wordCount && { wordCount: d.wordCount }),
        ...(props.type === 'newsArticle' && (d as NewsArticleData).sourceUrl && {
          isBasedOn: (d as NewsArticleData).sourceUrl,
        }),
      };
    }

    case 'breadcrumb': {
      const d = props.data;
      if (!d.breadcrumbs.length) return null;
      return {
        '@type': 'BreadcrumbList',
        itemListElement: d.breadcrumbs.map((item, index) => ({
          '@type': 'ListItem',
          position: index + 1,
          name: item.name,
          item: item.url,
        })),
      };
    }

    case 'game': {
      const d = props.data;
      return {
        '@type': 'Game',
        name: d.name,
        description: d.description,
        url: d.url,
        gamePlatform: 'Tabletop',
        ...(d.image && { image: d.image }),
        ...(d.datePublished && { datePublished: d.datePublished.toISOString() }),
        ...(d.dateModified && { dateModified: d.dateModified.toISOString() }),
        ...(d.releaseYear && { copyrightYear: d.releaseYear }),
        ...(d.publisher && {
          publisher: {
            '@type': 'Organization',
            name: d.publisher.name,
            ...(d.publisher.url && { url: d.publisher.url }),
          },
        }),
        ...(d.designers?.length && {
          author: d.designers.map((p) => ({
            '@type': 'Person',
            name: p.name,
            ...(p.url && { url: p.url }),
          })),
        }),
        ...(d.genre?.length && { genre: d.genre }),
      };
    }

    case 'person': {
      const d = props.data;
      return {
        '@type': 'Person',
        name: d.name,
        description: d.description,
        url: d.url,
        ...(d.image && { image: d.image }),
        ...(d.jobTitles?.length && { jobTitle: d.jobTitles }),
        ...(d.affiliations?.length && {
          affiliation: d.affiliations.map((org) => ({
            '@type': 'Organization',
            name: org.name,
            ...(org.url && { url: org.url }),
          })),
        }),
        ...(d.sameAs?.length && { sameAs: d.sameAs }),
      };
    }

    case 'videoObject': {
      const d = props.data;
      return {
        '@type': 'VideoObject',
        name: d.name,
        description: d.description,
        thumbnailUrl: d.thumbnailUrl,
        uploadDate: d.uploadDate.toISOString(),
        embedUrl: `https://www.youtube.com/embed/${d.youtubeId}`,
        contentUrl: `https://www.youtube.com/watch?v=${d.youtubeId}`,
      };
    }

    default:
      return null;
  }
}

const schema = buildSchema();
const jsonLd = schema ? { '@context': 'https://schema.org', ...schema } : null;
---

{jsonLd && (
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
)}
