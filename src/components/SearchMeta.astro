---
/**
 * Hidden search metadata for Pagefind. Render inside a `data-pagefind-body`
 * region on entity pages.
 *
 * - description → sets Pagefind meta.description (shown as the result snippet
 *   instead of a harvested page excerpt or raw transcript text). Also carries
 *   the coarse `type` filter (Pagefind needs one filter per element, so it
 *   can't be comma-combined onto <main> alongside `category`).
 * - aliases → alternate spellings/spacings/abbreviations, indexed as body text
 *   (heavily weighted) so e.g. "relic blade" finds the "Relicblade" entry.
 */
interface Props {
  description?: string;
  aliases?: string[];
  type?: string;
}

const { description, aliases = [], type } = Astro.props;
---

{description && (
  <span
    class="sr-only"
    data-pagefind-meta="description"
    data-pagefind-filter={type ? `type:${type}` : undefined}
  >{description}</span>
)}
{aliases.length > 0 && (
  <span class="sr-only" data-pagefind-weight="10">{aliases.join(' ')}</span>
)}
